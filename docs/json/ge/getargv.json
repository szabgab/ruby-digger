{"gems":{"name":"getargv","downloads":6562,"version":"0.3.16","version_created_at":"2026-03-21T15:13:19.140Z","version_downloads":19,"platform":"universal-darwin","authors":"Camden Narzt","info":"== Getargv\nGetargv is a gem that allows you to query the arguments of other processes as an array or string.\n\nThis gem only supports macOS because the +KERN_PROCARGS2+ sysctl only exists in xnu kernels, BSD or Linux users should just read <code>/proc/$PID/cmdline</code> which is much easier and faster, Solaris users should use pargs.\n\nThis gem requires you have {libgetargv}[https://getargv.narzt.cam/] installed.\n\nTo limit the getargv gem to Apple OSs add it to your Gemfile like so:\n\n  gem \"getargv\", \"~> 0.3.16\", platforms: :ruby, install_if: RbConfig::CONFIG[\"host_os\"].include?(\"darwin\")\n","licenses":["BSD-3-Clause"],"metadata":{"funding_uri":"https://github.com/sponsors/CamJN","homepage_uri":"https://getargv.narzt.cam/","changelog_uri":"https://github.com/getargv/getargv.rb/blob/v0.3.16/CHANGELOG.md","bug_tracker_uri":"https://github.com/getargv/getargv.rb/issues","source_code_uri":"https://github.com/getargv/getargv.rb","documentation_uri":"https://rubydoc.info/gems/getargv/Getargv"},"yanked":false,"sha":"49a4a5acac28420212b005080961646b276b1856433ffbfe16539b27eb38056e","spec_sha":"788efb56e854c33d4e3c85105ce9127fc0d692529a6daf4158c40e400c4bac46","project_uri":"https://rubygems.org/gems/getargv","gem_uri":"https://rubygems.org/gems/getargv-0.3.16-universal-darwin.gem","homepage_uri":"https://getargv.narzt.cam/","wiki_uri":null,"documentation_uri":"https://rubydoc.info/gems/getargv/Getargv","mailing_list_uri":null,"source_code_uri":"https://github.com/getargv/getargv.rb","bug_tracker_uri":"https://github.com/getargv/getargv.rb/issues","changelog_uri":"https://github.com/getargv/getargv.rb/blob/v0.3.16/CHANGELOG.md","funding_uri":"https://github.com/sponsors/CamJN","dependencies":{"development":[{"name":"bump","requirements":">= 0"},{"name":"minitest","req