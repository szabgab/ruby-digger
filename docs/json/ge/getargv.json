{"gems":{"name":"getargv","downloads":7270,"version":"0.3.19","version_created_at":"2026-04-24T17:21:18.633Z","version_downloads":15,"platform":"universal-darwin","authors":"Camden Narzt","info":"== Getargv\nGetargv is a gem that allows you to query the arguments of other processes as an array or string.\n\nThis gem only supports macOS because the +KERN_PROCARGS2+ sysctl only exists in xnu kernels, BSD or Linux users should just read <code>/proc/$PID/cmdline</code> which is much easier and faster, Solaris users should use pargs.\n\nThis gem requires you have {libgetargv}[https://getargv.narzt.cam/] installed.\n\nTo limit the getargv gem to Apple OSs add it to your Gemfile like so:\n\n  gem \"getargv\", \"~> 0.3.19\", platforms: :ruby, install_if: RbConfig::CONFIG[\"host_os\"].include?(\"darwin\")\n","licenses":["BSD-3-Clause"],"metadata":{"funding_uri":"https://github.com/sponsors/CamJN","homepage_uri":"https://getargv.narzt.cam/","changelog_uri":"https://github.com/getargv/getargv.rb/blob/v0.3.19/CHANGELOG.md","bug_tracker_uri":"https://github.com/getargv/getargv.rb/issues","source_code_uri":"https://github.com/getargv/getargv.rb","documentation_uri":"https://rubydoc.info/gems/getargv/Getargv"},"yanked":false,"sha":"5f912361216441776e8efaab74c30451f8e79206f223ca02906a782d7ee001ff","spec_sha":"631ba4a97011090a1976ffa01392f4e4f6d0dcc98951e971fc14e60d8e8b56b2","project_uri":"https://rubygems.org/gems/getargv","gem_uri":"https://rubygems.org/gems/getargv-0.3.19-universal-darwin.gem","homepage_uri":"https://getargv.narzt.cam/","wiki_uri":null,"documentation_uri":"https://rubydoc.info/gems/getargv/Getargv","mailing_list_uri":null,"source_code_uri":"https://github.com/getargv/getargv.rb","bug_tracker_uri":"https://github.com/getargv/getargv.rb/issues","changelog_uri":"https://github.com/getargv/getargv.rb/blob/v0.3.19/CHANGELOG.md","funding_uri":"https://github.com/sponsors/CamJN","dependencies":{"development":[{"name":"bump","requirements":">= 0"},{"name":"minitest","req