{"gems":{"name":"solid_stack_web","downloads":1256,"version":"1.4.0","version_created_at":"2026-05-28T12:40:54.633Z","version_downloads":25,"platform":"ruby","authors":"Chuck Smith","info":"SolidStackWeb is a mountable Rails engine that provides a production-ready operations dashboard for the full Solid Stack. It covers Solid Queue (job browser, failed job retry with inline argument editing, queue pause/resume, recurring tasks, performance stats, CSV export, and alert webhooks), Solid Cache (entry browser, size distribution, 24-hour write timeline, and optional value preview), and Solid Cable (channel browser, per-channel message list, and purge controls). Ships with dark mode, Turbo Stream responses, a JSON metrics endpoint, and no asset pipeline dependency.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/eclectic-coding/solid_stack_web","changelog_uri":"https://github.com/eclectic-coding/solid_stack_web/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/eclectic-coding/solid_stack_web"},"yanked":false,"sha":"ee8a66f1a40c8b22828860f82f3085201476c08bc17a70d5cccb3359e0ecee63","spec_sha":"e2fd0d641e61db6b1cf83e968afbf58c043cd32a3118a9d216c38f6c9f272e40","project_uri":"https://rubygems.org/gems/solid_stack_web","gem_uri":"https://rubygems.org/gems/solid_stack_web-1.4.0.gem","homepage_uri":"https://github.com/eclectic-coding/solid_stack_web","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/eclectic-coding/solid_stack_web","bug_tracker_uri":null,"changelog_uri":"https://github.com/eclectic-coding/solid_stack_web/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"csv","requirements":">= 3.0"},{"name":"importmap-rails","requirements":">= 1.2"},{"name":"pagy","requirements":">= 43.0"},{"name":"rails","requirements":">= 8.1.3"},{"name":"solid_cable","requirements":">= 1.0"},{"name":"solid_cache","requirements":">= 1.0"},{"name":"solid_queue","requi