{"gems":{"name":"solid_stack_web","downloads":955,"version":"1.2.0","version_created_at":"2026-05-27T14:08:00.887Z","version_downloads":31,"platform":"ruby","authors":"Chuck Smith","info":"SolidStackWeb is a mountable Rails engine that provides a production-ready operations dashboard for the full Solid Stack. It covers Solid Queue (job browser, failed job retry with inline argument editing, queue pause/resume, recurring tasks, performance stats, CSV export, and alert webhooks), Solid Cache (entry browser, size distribution, 24-hour write timeline, and optional value preview), and Solid Cable (channel browser, per-channel message list, and purge controls). Ships with dark mode, Turbo Stream responses, a JSON metrics endpoint, and no asset pipeline dependency.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/eclectic-coding/solid_stack_web","changelog_uri":"https://github.com/eclectic-coding/solid_stack_web/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/eclectic-coding/solid_stack_web"},"yanked":false,"sha":"34d19a219141f4a89b2027796ba921eb582eb0a625ef8c3ea225525e8756c566","spec_sha":"431cbf44262f9abe3b513e8a2618c9b542d8ed09136c9b62e0e10528b9ae5a7d","project_uri":"https://rubygems.org/gems/solid_stack_web","gem_uri":"https://rubygems.org/gems/solid_stack_web-1.2.0.gem","homepage_uri":"https://github.com/eclectic-coding/solid_stack_web","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/eclectic-coding/solid_stack_web","bug_tracker_uri":null,"changelog_uri":"https://github.com/eclectic-coding/solid_stack_web/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"csv","requirements":">= 3.0"},{"name":"importmap-rails","requirements":">= 1.2"},{"name":"pagy","requirements":">= 43.0"},{"name":"rails","requirements":">= 8.1.3"},{"name":"solid_cable","requirements":">= 1.0"},{"name":"solid_cache","requirements":">= 1.0"},{"name":"solid_queue","requir