{"gems":{"name":"pg_canary","downloads":2473,"version":"0.3.0","version_created_at":"2026-07-19T23:31:00.864Z","version_downloads":115,"platform":"ruby","authors":"kyuuri1791","info":"pg_canary watches queries executed in development/test, parses them with PostgreSQL's own parser (pg_query), and combines the AST with schema metadata (indexes, column types) to warn about anti-patterns that can become slow queries in production: leading-wildcard LIKEs, function-wrapped columns in WHERE, ORDER BY RANDOM(), NOT IN (SELECT ...), and more.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/kyuuri1791/pg_canary","changelog_uri":"https://github.com/kyuuri1791/pg_canary/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/kyuuri1791/pg_canary","rubygems_mfa_required":"true"},"yanked":false,"sha":"91542c286dcddde4a1c76c594e6c3d68e21bc9a208942916caee87b65d1001c8","spec_sha":"4fb104fbd6126b7ec63922e2b3601cb6a0322ad979eaf402dc2cdad46ec86b96","project_uri":"https://rubygems.org/gems/pg_canary","gem_uri":"https://rubygems.org/gems/pg_canary-0.3.0.gem","homepage_uri":"https://github.com/kyuuri1791/pg_canary","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/kyuuri1791/pg_canary","bug_tracker_uri":null,"changelog_uri":"https://github.com/kyuuri1791/pg_canary/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"activerecord","requirements":">= 7.0"},{"name":"activesupport","requirements":">= 7.0"},{"name":"pg_query","requirements":">= 5.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/kyuuri1791/pg_canary"}