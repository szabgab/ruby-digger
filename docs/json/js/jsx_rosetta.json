{"gems":{"name":"jsx_rosetta","downloads":340,"version":"0.4.0","version_created_at":"2026-05-11T17:02:08.360Z","version_downloads":33,"platform":"ruby","authors":"Sean McCleary","info":"jsx_rosetta is a JSX-to-Rails translator. It parses JSX via Babel\n(over a Node sidecar), lowers the parsed AST into a framework-agnostic\nsemantic IR, and emits target output via pluggable backends. The\ninitial backend produces ViewComponent classes paired with ERB\ntemplates; additional backends (Phlex, Slim, Phoenix LiveView, etc.)\ncan be added against the same IR.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","rubygems_mfa_required":"true"},"yanked":false,"sha":"ee933a7030336ba9a978030a39efb6f7fed7d90bbf10cf115678211a49265355","spec_sha":"d6b54663eda00b47237b564eaf3f76b79684565632fab01245a586005a79ab2f","project_uri":"https://rubygems.org/gems/jsx_rosetta","gem_uri":"https://rubygems.org/gems/jsx_rosetta-0.4.0.gem","homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mrinterweb/jsx_rosetta"}