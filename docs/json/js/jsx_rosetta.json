{"gems":{"name":"jsx_rosetta","downloads":88,"version":"0.2.0","version_created_at":"2026-05-10T09:37:44.030Z","version_downloads":37,"platform":"ruby","authors":"Sean McCleary","info":"jsx_rosetta is a JSX-to-Rails translator. It parses JSX via Babel\n(over a Node sidecar), lowers the parsed AST into a framework-agnostic\nsemantic IR, and emits target output via pluggable backends. The\ninitial backend produces ViewComponent classes paired with ERB\ntemplates; additional backends (Phlex, Slim, Phoenix LiveView, etc.)\ncan be added against the same IR.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","rubygems_mfa_required":"true"},"yanked":false,"sha":"ac66fadd5954a8ef0ba1bd3a689abef24327018ac609f3a98a0d97c5a14cbfbe","spec_sha":"76df540c15c33cf50a9c871275f099b7a07841beac1a974345faeefc4baa14c7","project_uri":"https://rubygems.org/gems/jsx_rosetta","gem_uri":"https://rubygems.org/gems/jsx_rosetta-0.2.0.gem","homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mrinterweb/jsx_rosetta"}