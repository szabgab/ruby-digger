{"gems":{"name":"jsx_rosetta","downloads":598,"version":"0.6.0","version_created_at":"2026-05-13T23:26:07.603Z","version_downloads":41,"platform":"ruby","authors":"Sean McCleary","info":"jsx_rosetta is a JSX-to-Rails translator. It parses JSX via Babel\n(over a Node sidecar), lowers the parsed AST into a framework-agnostic\nsemantic IR, and emits target output via pluggable backends. The\ninitial backend produces ViewComponent classes paired with ERB\ntemplates; additional backends (Phlex, Slim, Phoenix LiveView, etc.)\ncan be added against the same IR.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","rubygems_mfa_required":"true"},"yanked":false,"sha":"1f63066bd8cf0a837cad29d22ce292d8d4159052e7b6ee7f174bb11f39a5c164","spec_sha":"eb65515e599078964b3879cce10c1610597c092175569c77117c02b6a36852f7","project_uri":"https://rubygems.org/gems/jsx_rosetta","gem_uri":"https://rubygems.org/gems/jsx_rosetta-0.6.0.gem","homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mrinterweb/jsx_rosetta"}