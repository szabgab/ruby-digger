{"gems":{"name":"jsx_rosetta","downloads":427,"version":"0.5.1","version_created_at":"2026-05-11T22:28:12.796Z","version_downloads":35,"platform":"ruby","authors":"Sean McCleary","info":"jsx_rosetta is a JSX-to-Rails translator. It parses JSX via Babel\n(over a Node sidecar), lowers the parsed AST into a framework-agnostic\nsemantic IR, and emits target output via pluggable backends. The\ninitial backend produces ViewComponent classes paired with ERB\ntemplates; additional backends (Phlex, Slim, Phoenix LiveView, etc.)\ncan be added against the same IR.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","rubygems_mfa_required":"true"},"yanked":false,"sha":"511d679571015a0408d13ef9de34e13e792b89899f3d480c21970e6cae78cc35","spec_sha":"46c7a70505dacba6d0a36ff5556b2e5c065a00fb6aa3dc2966f1754b3839d4e5","project_uri":"https://rubygems.org/gems/jsx_rosetta","gem_uri":"https://rubygems.org/gems/jsx_rosetta-0.5.1.gem","homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mrinterweb/jsx_rosetta"}