{"gems":{"name":"jsx_rosetta","downloads":181,"version":"0.3.0","version_created_at":"2026-05-10T17:20:06.348Z","version_downloads":47,"platform":"ruby","authors":"Sean McCleary","info":"jsx_rosetta is a JSX-to-Rails translator. It parses JSX via Babel\n(over a Node sidecar), lowers the parsed AST into a framework-agnostic\nsemantic IR, and emits target output via pluggable backends. The\ninitial backend produces ViewComponent classes paired with ERB\ntemplates; additional backends (Phlex, Slim, Phoenix LiveView, etc.)\ncan be added against the same IR.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","rubygems_mfa_required":"true"},"yanked":false,"sha":"e0dcd2179570e9efa3710e427854e425a117f0d7ba7ab0791123712ade81863c","spec_sha":"447200634c691201ba0f9f09506ab2d9d0930ae21f5a81d5b1c8c844009cd56f","project_uri":"https://rubygems.org/gems/jsx_rosetta","gem_uri":"https://rubygems.org/gems/jsx_rosetta-0.3.0.gem","homepage_uri":"https://github.com/mrinterweb/jsx_rosetta","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/mrinterweb/jsx_rosetta","bug_tracker_uri":"https://github.com/mrinterweb/jsx_rosetta/issues","changelog_uri":"https://github.com/mrinterweb/jsx_rosetta/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mrinterweb/jsx_rosetta"}