{"gems":{"name":"dedupe_requests","downloads":234,"version":"1.0.0","version_created_at":"2026-06-24T06:33:12.935Z","version_downloads":155,"platform":"ruby","authors":"Tilo Sloboda","info":"Detects and rejects duplicate inbound POST/PUT/PATCH requests with a 409/conflict, with no client-side idempotency key required. The server auto-computes a fingerprint of each mutating request, claims it atomically in Redis, and short-circuits duplicates seen within a configurable time window, so they don't overwhelm your server or cause 5xx errors.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/tilo/dedupe_requests","changelog_uri":"https://github.com/tilo/dedupe_requests/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/tilo/dedupe_requests","rubygems_mfa_required":"false"},"yanked":false,"sha":"6243e42e2ec54c46f3736404b6a0d753f9416fab85123dbba0c5cf3dbd59e816","spec_sha":"3e6925b77560d91c8f564f775bdcccb1a18b52ecedf49d5a822c4e9cc34e6464","project_uri":"https://rubygems.org/gems/dedupe_requests","gem_uri":"https://rubygems.org/gems/dedupe_requests-1.0.0.gem","homepage_uri":"https://github.com/tilo/dedupe_requests","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/tilo/dedupe_requests","bug_tracker_uri":null,"changelog_uri":"https://github.com/tilo/dedupe_requests/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"rake","requirements":"~> 13.0"},{"name":"rspec","requirements":"~> 3.0"}],"runtime":[{"name":"activesupport","requirements":">= 5.2"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/tilo/dedupe_requests"}