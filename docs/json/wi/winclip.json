{"gems":{"name":"winclip","downloads":343,"version":"0.1.1","version_created_at":"2026-06-28T20:48:42.846Z","version_downloads":95,"platform":"ruby","authors":"ned","info":"winclip is a native Windows clipboard library for Ruby. It gets and sets\nUnicode text, images (as PNG bytes, converted to/from CF_DIB/CF_DIBV5 via\nWIC), and file lists (CF_HDROP), plus clear, format introspection, and\nhas_text?/has_image?/has_files? queries. The PNG image interface pairs\ndirectly with the windraw gem. Windows MSVC (mswin) Ruby only.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/main-path/winclip","changelog_uri":"https://github.com/main-path/winclip/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/main-path/winclip/issues","rubygems_mfa_required":"true"},"yanked":false,"sha":"303ae0bd5ef2c2b518b8c24c2c943da1a0278547280f6714574e8614a425f5d9","spec_sha":"cab72445a07ef1cece4f0447592848762da2629961253c6c2b22a5e97617fcf3","project_uri":"https://rubygems.org/gems/winclip","gem_uri":"https://rubygems.org/gems/winclip-0.1.1.gem","homepage_uri":"https://github.com/main-path/winclip","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":"https://github.com/main-path/winclip/issues","changelog_uri":"https://github.com/main-path/winclip/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":"~> 13.0"},{"name":"rake-compiler","requirements":"~> 1.2"},{"name":"vcvars","requirements":"~> 0.1, >= 0.1.1"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/main-path/winclip"}