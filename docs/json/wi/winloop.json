{"gems":{"name":"winloop","downloads":346,"version":"0.2.0","version_created_at":"2026-06-28T20:56:28.406Z","version_downloads":83,"platform":"ruby","authors":"ned","info":"winloop is a Ruby Fiber::Scheduler built on Win32 I/O Completion Ports. It\nmakes ordinary socket I/O, sleeps, timeouts and Mutex/Queue/Thread#join run\ncooperatively on a single thread — the async-runtime story that has always\nbeen weak on Windows, done the way libuv/mio/wepoll do it: readiness over an\nIOCP via \\Device\\Afd polling, with recv/send driven by the completion port.\nRequires a native Windows MSVC (mswin) build of Ruby.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/main-path/winloop","changelog_uri":"https://github.com/main-path/winloop/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/main-path/winloop/issues","source_code_uri":"https://github.com/main-path/winloop","allowed_push_host":"https://rubygems.org","rubygems_mfa_required":"true"},"yanked":false,"sha":"2420b58ca89bce45f66a5e7147cf5a0a0d8f1d49b5fe6903cee043a3e8779a66","spec_sha":"bbde6d92461b767c879acabf1bff526453932be66487016f4ca623772e1d721c","project_uri":"https://rubygems.org/gems/winloop","gem_uri":"https://rubygems.org/gems/winloop-0.2.0.gem","homepage_uri":"https://github.com/main-path/winloop","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/main-path/winloop","bug_tracker_uri":"https://github.com/main-path/winloop/issues","changelog_uri":"https://github.com/main-path/winloop/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":"~> 13.0"},{"name":"rake-compiler","requirements":"~> 1.2"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/main-path/winloop"}