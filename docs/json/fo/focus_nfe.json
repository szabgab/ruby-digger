{"gems":{"name":"focus_nfe","downloads":201,"version":"1.0.1","version_created_at":"2026-07-03T20:28:31.094Z","version_downloads":99,"platform":"ruby","authors":"wilfison","info":"Cliente Ruby não-oficial para a API da Focus NFe (focusnfe.com.br), serviço brasileiro de emissão de documentos fiscais eletrônicos. Cobre os documentos emitidos (NFe, NFCe, NFSe, NFSe nacional, CTe, CTe OS, MDFe, NFCom, DCe, NFGas), recebidos, APIs auxiliares (CEP, CNPJ, municípios, CFOP, CNAE, NCM) e de gestão (empresas, webhooks). Suporta multi-empresa, erros tipados por status HTTP e validação client-side opt-in por schemas, sem dependências de runtime.","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/wilfison/focus_nfe/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/wilfison/focus_nfe","rubygems_mfa_required":"true"},"yanked":false,"sha":"eaecfa4f7153278a8dbd4b113abf761e05e1c09af7a3f5bd465765bc4d7980f2","spec_sha":"abfc4557b49fb0deb89cf02fca0fce4ce38c0336e1524a0f1af8bfef1d9210a6","project_uri":"https://rubygems.org/gems/focus_nfe","gem_uri":"https://rubygems.org/gems/focus_nfe-1.0.1.gem","homepage_uri":"https://github.com/wilfison/focus_nfe","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/wilfison/focus_nfe","bug_tracker_uri":null,"changelog_uri":"https://github.com/wilfison/focus_nfe/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"overcommit","requirements":"~> 0.71"},{"name":"rake","requirements":"~> 13.3"},{"name":"rspec","requirements":"~> 3.13"},{"name":"rubocop","requirements":"~> 1.86"},{"name":"rubocop-performance","requirements":"~> 1.25"},{"name":"rubocop-rspec","requirements":"~> 3.6"},{"name":"simplecov","requirements":"~> 0.22"},{"name":"steep","requirements":"~> 2.0"},{"name":"vcr","requirements":"~> 6.3"},{"name":"webmock","requirements":"~> 3.25"},{"name":"webrick","requirements":"~> 1.9"},{"name":"yard","requirements":"~> 0.9"}],"runtime":[]}},"vc