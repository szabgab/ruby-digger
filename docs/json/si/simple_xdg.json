{"gems":{"name":"simple_xdg","downloads":378,"version":"0.1.1","version_created_at":"2026-05-04T23:19:22.470Z","version_downloads":58,"platform":"ruby","authors":"Daniel Azuma","info":"This class provides a simple no-frills implementation of the XDG Base Directory Specification, which defines where certain user-specific application files, such as configuration, cache, and saved state, should live on the user's file system. It specifies environment variables that contain this information, and defaults that should be used if those environment variables are unset. The spec itself is at https://specifications.freedesktop.org/basedir/latest/","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/dazuma/simple_xdg","changelog_uri":"https://rubydoc.info/gems/simple_xdg/0.1.1/file/CHANGELOG.md","bug_tracker_uri":"https://github.com/dazuma/simple_xdg/issues","documentation_uri":"https://rubydoc.info/gems/simple_xdg/0.1.1"},"yanked":false,"sha":"53e2bd4206e80e2a631cf89a8ff6ac0f23c1d3ed7ec0be65549df44691bd4377","spec_sha":"be153941e2862e17ca85d86370ea0cfc6dd3b32d06769c2826a79f0ced523845","project_uri":"https://rubygems.org/gems/simple_xdg","gem_uri":"https://rubygems.org/gems/simple_xdg-0.1.1.gem","homepage_uri":"https://github.com/dazuma/simple_xdg","wiki_uri":null,"documentation_uri":"https://rubydoc.info/gems/simple_xdg/0.1.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":"https://github.com/dazuma/simple_xdg/issues","changelog_uri":"https://rubydoc.info/gems/simple_xdg/0.1.1/file/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"logger","requirements":">= 0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/dazuma/simple_xdg"}