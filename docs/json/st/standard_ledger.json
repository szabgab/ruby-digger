{"gems":{"name":"standard_ledger","downloads":276,"version":"0.4.0","version_created_at":"2026-05-07T06:25:01.687Z","version_downloads":33,"platform":"ruby","authors":"Jaryl Sim","info":"StandardLedger captures the recurring 'append-only entry → N projection updates' pattern as a declarative DSL on host ActiveRecord models. Supports five projection modes — :inline, :async, :sql, :matview, :trigger — plus a deterministic rebuild path from the entry log, ad-hoc materialized view refresh, and a doctor rake task that verifies host-owned trigger presence. Enforces idempotency-by-unique-index and immutability at the entry level.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/rarebit-one/standard_ledger","changelog_uri":"https://github.com/rarebit-one/standard_ledger/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/rarebit-one/standard_ledger/issues","source_code_uri":"https://github.com/rarebit-one/standard_ledger"},"yanked":false,"sha":"bb7cc00d524e5004b222b4f25aee1f5dcb38dce652638d810d133b3f16bfa3cc","spec_sha":"5aa725c3dd62617416863a37eaeb307b0d5e1541b8830e8735623ce9f35bc7e1","project_uri":"https://rubygems.org/gems/standard_ledger","gem_uri":"https://rubygems.org/gems/standard_ledger-0.4.0.gem","homepage_uri":"https://github.com/rarebit-one/standard_ledger","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/rarebit-one/standard_ledger","bug_tracker_uri":"https://github.com/rarebit-one/standard_ledger/issues","changelog_uri":"https://github.com/rarebit-one/standard_ledger/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"brakeman","requirements":">= 0"},{"name":"bundler-audit","requirements":">= 0"},{"name":"simplecov","requirements":">= 0"}],"runtime":[{"name":"activejob","requirements":">= 8.0"},{"name":"activerecord","requirements":">= 8.0"},{"name":"activesupport","requirements":">= 8.0"},{"name":"concurrent-ruby","requirements":"~> 1.3"},{"name":"r