{"gems":{"name":"strict_lazy","downloads":209,"version":"0.4.0","version_created_at":"2026-06-15T22:18:26.567Z","version_downloads":29,"platform":"ruby","authors":"aki77","info":"strict_lazy applies the spirit of Rails' strict_loading to computed values\n(external APIs, window functions, cross-table aggregates) that associations\ncannot express. It forces explicit preloading and raises on unloaded access\nin development/test, so hidden per-record queries never slip into views.\nNo batch-loader / N1Loader / ar_lazy_preload dependency — activesupport only.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/aki77/strict_lazy","changelog_uri":"https://github.com/aki77/strict_lazy/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/aki77/strict_lazy","rubygems_mfa_required":"true"},"yanked":false,"sha":"ee507aa68d8dbe9a283c6793d90e2c5935084457cfb735cb9b7873340ef99974","spec_sha":"9079f4f41e97de5a7ba39d458dd31c0cf369f79bc95d11a10010ed05feaaea0f","project_uri":"https://rubygems.org/gems/strict_lazy","gem_uri":"https://rubygems.org/gems/strict_lazy-0.4.0.gem","homepage_uri":"https://github.com/aki77/strict_lazy","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/aki77/strict_lazy","bug_tracker_uri":null,"changelog_uri":"https://github.com/aki77/strict_lazy/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"activesupport","requirements":">= 8.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/aki77/strict_lazy"}