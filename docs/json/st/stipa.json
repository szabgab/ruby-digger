{"gems":{"name":"stipa","downloads":311,"version":"0.1.6","version_created_at":"2026-03-21T02:14:29.351Z","version_downloads":23,"platform":"ruby","authors":"Pedro Harbs","info":"Stīpa is a lightweight, zero-dependency HTTP/1.1 framework built entirely on Ruby stdlib.\n\nFeatures:\n- Pure stdlib (socket, thread, erb, json, securerandom)\n- HTTP/1.1 with keep-alive, SO_REUSEPORT, and TCP_NODELAY\n- Thread pool with bounded queue and graceful shutdown\n- Pre-compiled middleware stack with zero per-request overhead\n- ERB templates with layouts, partials, and Vue 3 island helpers\n- CLI generator for MVC and API-only applications\n- Structured logging in logfmt format\n- Named route parameters via regex captures\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/pedroharbs/stipa","changelog_uri":"https://github.com/pedroharbs/stipa/releases","bug_tracker_uri":"https://github.com/pedroharbs/stipa/issues","source_code_uri":"https://github.com/pedroharbs/stipa","documentation_uri":"https://github.com/pedroharbs/stipa","rubygems_mfa_required":"true"},"yanked":false,"sha":"15e8293a4074cf2ce8d5090387f09cc301abaeffcdd807f54a421aa4ccb4c4e4","spec_sha":"a68520315e5039cb9992c143e8c99c941d3e57362d732c2c5ec44639f90cb38b","project_uri":"https://rubygems.org/gems/stipa","gem_uri":"https://rubygems.org/gems/stipa-0.1.6.gem","homepage_uri":"https://github.com/pedroharbs/stipa","wiki_uri":null,"documentation_uri":"https://github.com/pedroharbs/stipa","mailing_list_uri":null,"source_code_uri":"https://github.com/pedroharbs/stipa","bug_tracker_uri":"https://github.com/pedroharbs/stipa/issues","changelog_uri":"https://github.com/pedroharbs/stipa/releases","funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":"~> 5.20"},{"name":"rake","requirements":"~> 13.0"},{"name":"rubocop","requirements":"~> 1.50"},{"name":"yard","requirements":"~> 0.9"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/pedroharbs/stipa"}