{"gems":{"name":"stipa","downloads":230,"version":"0.1.5","version_created_at":"2026-03-21T01:24:00.628Z","version_downloads":5,"platform":"ruby","authors":"Pedro Harbs","info":"Stīpa is a lightweight, zero-dependency HTTP/1.1 framework built entirely on Ruby stdlib.\n\nFeatures:\n- Pure stdlib (socket, thread, erb, json, securerandom)\n- HTTP/1.1 with keep-alive, SO_REUSEPORT, and TCP_NODELAY\n- Thread pool with bounded queue and graceful shutdown\n- Pre-compiled middleware stack with zero per-request overhead\n- ERB templates with layouts, partials, and Vue 3 island helpers\n- CLI generator for MVC and API-only applications\n- Structured logging in logfmt format\n- Named route parameters via regex captures\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/pedroharbs/stipa","changelog_uri":"https://github.com/pedroharbs/stipa/releases","bug_tracker_uri":"https://github.com/pedroharbs/stipa/issues","source_code_uri":"https://github.com/pedroharbs/stipa","documentation_uri":"https://github.com/pedroharbs/stipa","rubygems_mfa_required":"true"},"yanked":false,"sha":"46dc76d08d28d004abbae0a1da6f2169d30ea8f37638466f4089bb7d1f720c65","spec_sha":"b1af30645f113ec198f4c21559c2cf5df691c34fb0ddcff3ae9ec1ce6cd631c4","project_uri":"https://rubygems.org/gems/stipa","gem_uri":"https://rubygems.org/gems/stipa-0.1.5.gem","homepage_uri":"https://github.com/pedroharbs/stipa","wiki_uri":null,"documentation_uri":"https://github.com/pedroharbs/stipa","mailing_list_uri":null,"source_code_uri":"https://github.com/pedroharbs/stipa","bug_tracker_uri":"https://github.com/pedroharbs/stipa/issues","changelog_uri":"https://github.com/pedroharbs/stipa/releases","funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":"~> 5.20"},{"name":"rake","requirements":"~> 13.0"},{"name":"rubocop","requirements":"~> 1.50"},{"name":"yard","requirements":"~> 0.9"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/pedroharbs/stipa"}