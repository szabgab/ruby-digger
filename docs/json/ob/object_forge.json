{"gems":{"name":"object_forge","downloads":1160,"version":"0.4.0","version_created_at":"2026-05-28T10:19:14.218Z","version_downloads":31,"platform":"ruby","authors":"Alexander Bulancov","info":"ObjectForge is a small factory library for Ruby objects with minimal assumptions\nabout framework, persistence, or runtime environment.\n\nIt is designed for cases where factory-style object construction is useful,\nbut Rails-oriented or database-oriented tooling is a poor fit. ObjectForge\nworks well with plain Ruby objects, hashes, structs, and custom build flows.\n\nThe library focuses on explicit configuration, independent registries and factories,\nand replaceable components. It aims to provide a familiar workflow without\ncoupling object generation to a framework or persistence layer.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/trinistr/object_forge","changelog_uri":"https://github.com/trinistr/object_forge/blob/v0.4.0/CHANGELOG.md","bug_tracker_uri":"https://github.com/trinistr/object_forge/issues","source_code_uri":"https://github.com/trinistr/object_forge/tree/v0.4.0","documentation_uri":"https://rubydoc.info/gems/object_forge/0.4.0","rubygems_mfa_required":"true"},"yanked":false,"sha":"a7374dd772d0e92b1ea8bb8fef5c70928d58dfb89618fd47dff221f5c12758ff","spec_sha":"19fd45bd87144572e95488497735ba220e736329732d36c0a2bc5bc0c5ea86f7","project_uri":"https://rubygems.org/gems/object_forge","gem_uri":"https://rubygems.org/gems/object_forge-0.4.0.gem","homepage_uri":"https://github.com/trinistr/object_forge","wiki_uri":null,"documentation_uri":"https://rubydoc.info/gems/object_forge/0.4.0","mailing_list_uri":null,"source_code_uri":"https://github.com/trinistr/object_forge/tree/v0.4.0","bug_tracker_uri":"https://github.com/trinistr/object_forge/issues","changelog_uri":"https://github.com/trinistr/object_forge/blob/v0.4.0/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"concurrent-ruby","requirements":"~> 1.2"}]}},"vc