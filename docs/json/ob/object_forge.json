{"gems":{"name":"object_forge","downloads":1508,"version":"0.5.0","version_created_at":"2026-06-19T09:20:11.699Z","version_downloads":35,"platform":"ruby","authors":"Alexander Bulancov","info":"ObjectForge is a small factory library for Ruby objects with minimal assumptions\nabout framework, persistence, or runtime environment.\n\nIt is designed for cases where factory-style object construction is useful,\nbut Rails-oriented or database-oriented tooling is a poor fit. ObjectForge\nworks well with plain Ruby objects, hashes, arrays, structs, and custom build flows.\n\nThe library focuses on explicit configuration, independent registries and factories,\nand replaceable components. It aims to provide a familiar workflow without\ncoupling object generation to a framework or persistence layer.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/trinistr/object_forge","changelog_uri":"https://github.com/trinistr/object_forge/blob/v0.5.0/CHANGELOG.md","bug_tracker_uri":"https://github.com/trinistr/object_forge/issues","source_code_uri":"https://github.com/trinistr/object_forge/tree/v0.5.0","documentation_uri":"https://rubydoc.info/gems/object_forge/0.5.0","rubygems_mfa_required":"true"},"yanked":false,"sha":"5fc921daa53046a626d1e3c39931c50d8c7f95e27fbd755cffd64bb1f1a93962","spec_sha":"be7075c472496774308dbeb6d26e0d7fd2d2219e72b5ad11d34c94248157296d","project_uri":"https://rubygems.org/gems/object_forge","gem_uri":"https://rubygems.org/gems/object_forge-0.5.0.gem","homepage_uri":"https://github.com/trinistr/object_forge","wiki_uri":null,"documentation_uri":"https://rubydoc.info/gems/object_forge/0.5.0","mailing_list_uri":null,"source_code_uri":"https://github.com/trinistr/object_forge/tree/v0.5.0","bug_tracker_uri":"https://github.com/trinistr/object_forge/issues","changelog_uri":"https://github.com/trinistr/object_forge/blob/v0.5.0/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"concurrent-ruby","requirements":"~> 1.2"