{"gems":{"name":"cafe_car","downloads":2114,"version":"0.3.1","version_created_at":"2026-07-13T18:46:07.793Z","version_downloads":115,"platform":"ruby","authors":"Jeff Peterson","info":"CafeCar is a composable view extension for Rails: it renders complete index, show, new, and edit interfaces straight from your models, with no DSL and no boilerplate. Every index ships with keyword search, URL-based filtering and sorting, pagination, and one-click CSV export. Authorization runs on Pundit with attribute-level permissions; forms and Turbo Stream (Hotwire) responses render automatically. Every default can be overridden application-wide or per model with ordinary Rails. It makes admin panels, internal tools, and back-office apps on Rails 8 trivial.","licenses":["MIT"],"metadata":{"homepage_uri":"https://craft-concept.github.io/cafe_car","changelog_uri":"https://github.com/craft-concept/cafe_car/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/craft-concept/cafe_car/issues","source_code_uri":"https://github.com/craft-concept/cafe_car","rubygems_mfa_required":"true"},"yanked":false,"sha":"c63d203e1787e43468ca8d6edb8c1ae575448364a3074e768f8b49d3094b3320","spec_sha":"d855bf9528e83b4a7d430f990690fb777a7105d2794cf0a8afdaace4dad5a030","project_uri":"https://rubygems.org/gems/cafe_car","gem_uri":"https://rubygems.org/gems/cafe_car-0.3.1.gem","homepage_uri":"https://craft-concept.github.io/cafe_car","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/craft-concept/cafe_car","bug_tracker_uri":"https://github.com/craft-concept/cafe_car/issues","changelog_uri":"https://github.com/craft-concept/cafe_car/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"activerecord_where_assoc","requirements":">= 1.3"},{"name":"chronic","requirements":">= 0.10"},{"name":"haml-rails","requirements":">= 3.0"},{"name":"image_processing","requirements":">= 1.13"},{"name":"importmap-rails","requir