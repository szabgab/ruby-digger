{"gems":{"name":"kirei","downloads":8739,"version":"0.9.0","version_created_at":"2026-03-22T15:24:49.861Z","version_downloads":32,"platform":"ruby","authors":"Ludwig Reinmiedl","info":"Kirei is a Ruby micro/REST-framework for building scalable and performant microservices.\nIt is built from the ground up to be clean and easy to use.\nIt is a Rack app, and uses Sorbet for typing, Sequel as an ORM, and Zeitwerk for autoloading.\nIt strives to have zero magic and to be as explicit as possible.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/swiknaba/kirei","rubygems_mfa_required":"true"},"yanked":false,"sha":"6b4ba025af60e4a18f75d0a0076fb54a1aea97a9fa6e7f47472e6c86ecf236c9","spec_sha":"fd5e958164a16a18b6b5c48bba1065268c68d1493e7d629738c37b8b15c5f2cd","project_uri":"https://rubygems.org/gems/kirei","gem_uri":"https://rubygems.org/gems/kirei-0.9.0.gem","homepage_uri":"https://github.com/swiknaba/kirei","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"logger","requirements":"~> 1.5"},{"name":"oj","requirements":"~> 3.0"},{"name":"pg","requirements":"~> 1.0"},{"name":"rack","requirements":"~> 3.0"},{"name":"sequel","requirements":"~> 5.0"},{"name":"sequel_pg","requirements":"~> 1.0"},{"name":"sorbet-runtime","requirements":"~> 0.5"},{"name":"tzinfo-data","requirements":"~> 1.0"},{"name":"zeitwerk","requirements":"~> 2.5"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/swiknaba/kirei"}