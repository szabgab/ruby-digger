{"gems":{"name":"kirei","downloads":9198,"version":"0.9.3","version_created_at":"2026-03-28T06:35:39.730Z","version_downloads":39,"platform":"ruby","authors":"Ludwig Reinmiedl","info":"Kirei is a Ruby micro/REST-framework for building scalable and performant microservices.\nIt is built from the ground up to be clean and easy to use.\nIt is a Rack app, and uses Sorbet for typing, Sequel as an ORM, and Zeitwerk for autoloading.\nIt strives to have zero magic and to be as explicit as possible.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/swiknaba/kirei","rubygems_mfa_required":"true"},"yanked":false,"sha":"16d20ef865ca6105bd06fa17c7cc44c52e5e7daea98310bc6f33f07a6606b731","spec_sha":"5c9ca44d6d6877d5875b6835b6607807cdea50ec37ba32a76e0c65a442460799","project_uri":"https://rubygems.org/gems/kirei","gem_uri":"https://rubygems.org/gems/kirei-0.9.3.gem","homepage_uri":"https://github.com/swiknaba/kirei","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"logger","requirements":"~> 1.5"},{"name":"oj","requirements":"~> 3.0"},{"name":"pg","requirements":"~> 1.0"},{"name":"rack","requirements":"~> 3.0"},{"name":"sequel","requirements":"~> 5.0"},{"name":"sequel_pg","requirements":"~> 1.0"},{"name":"sorbet-runtime","requirements":"~> 0.5"},{"name":"tzinfo-data","requirements":"~> 1.0"},{"name":"zeitwerk","requirements":"~> 2.5"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/swiknaba/kirei"}