{"gems":{"name":"kirei","downloads":8773,"version":"0.9.1","version_created_at":"2026-03-22T16:25:53.922Z","version_downloads":25,"platform":"ruby","authors":"Ludwig Reinmiedl","info":"Kirei is a Ruby micro/REST-framework for building scalable and performant microservices.\nIt is built from the ground up to be clean and easy to use.\nIt is a Rack app, and uses Sorbet for typing, Sequel as an ORM, and Zeitwerk for autoloading.\nIt strives to have zero magic and to be as explicit as possible.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/swiknaba/kirei","rubygems_mfa_required":"true"},"yanked":false,"sha":"cfc9e752d9b012fd1b7d6525fe236c67531a8b79c3bf338f9ccb8f29bd36b7ba","spec_sha":"2f1641b00ac43e374c8340b11bb34c6b34694e9d98c9846cc4cf3e6cba5bd5d0","project_uri":"https://rubygems.org/gems/kirei","gem_uri":"https://rubygems.org/gems/kirei-0.9.1.gem","homepage_uri":"https://github.com/swiknaba/kirei","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"logger","requirements":"~> 1.5"},{"name":"oj","requirements":"~> 3.0"},{"name":"pg","requirements":"~> 1.0"},{"name":"rack","requirements":"~> 3.0"},{"name":"sequel","requirements":"~> 5.0"},{"name":"sequel_pg","requirements":"~> 1.0"},{"name":"sorbet-runtime","requirements":"~> 0.5"},{"name":"tzinfo-data","requirements":"~> 1.0"},{"name":"zeitwerk","requirements":"~> 2.5"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/swiknaba/kirei"}