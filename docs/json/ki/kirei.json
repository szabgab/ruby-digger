{"gems":{"name":"kirei","downloads":10003,"version":"0.10.0","version_created_at":"2026-05-03T20:47:40.443Z","version_downloads":28,"platform":"ruby","authors":"Ludwig Reinmiedl","info":"Kirei is a Ruby micro/REST-framework for building scalable and performant microservices.\nIt is built from the ground up to be clean and easy to use.\nIt is a Rack app, and uses Sorbet for typing, Sequel as an ORM, and Zeitwerk for autoloading.\nIt strives to have zero magic and to be as explicit as possible.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/swiknaba/kirei","rubygems_mfa_required":"true"},"yanked":false,"sha":"eefd91f145d49e0a77b5d12ab0ca482c439dfc23fd5a15957cdba1a3f6c93321","spec_sha":"0c5f4ffec41bf1a4ac0eafc9473aa726f45b205b7e50fb46dea06143feb8fa94","project_uri":"https://rubygems.org/gems/kirei","gem_uri":"https://rubygems.org/gems/kirei-0.10.0.gem","homepage_uri":"https://github.com/swiknaba/kirei","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"logger","requirements":"~> 1.5"},{"name":"oj","requirements":"~> 3.0"},{"name":"pg","requirements":"~> 1.0"},{"name":"rack","requirements":"~> 3.0"},{"name":"sequel","requirements":"~> 5.0"},{"name":"sequel_pg","requirements":"~> 1.0"},{"name":"sorbet-runtime","requirements":"~> 0.5"},{"name":"tzinfo-data","requirements":"~> 1.0"},{"name":"zeitwerk","requirements":"~> 2.5"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/swiknaba/kirei"}