{"gems":{"name":"png_conform","downloads":5682,"version":"0.1.4","version_created_at":"2026-04-05T03:16:49.904Z","version_downloads":46,"platform":"ruby","authors":"Ribose Inc.","info":"PngConform provides a comprehensive PNG, MNG, and JNG file validation library\nin pure Ruby. It validates file structure, chunk validity, CRC checksums,\nzlib compression, and profile conformance. Built with a layered architecture\nusing BinData for binary parsing, Lutaml::Model for domain models, and Thor\nfor CLI. Supports PNG baseline, MNG-VLC, MNG-LC, and JNG profiles with\ndetailed validation reporting compatible with pngcheck output.\n","licenses":["BSD-2-Clause"],"metadata":{"homepage_uri":"https://github.com/claricle/png_conform","changelog_uri":"https://github.com/claricle/png_conform","source_code_uri":"https://github.com/claricle/png_conform","rubygems_mfa_required":"true"},"yanked":false,"sha":"cff7cff873bfbf45bb494cd93d9d76f8c8fcd0c32e8db2b770ac9b9ec519eea8","spec_sha":"c3a479c16abc32901afce31c8a45c64079ba32891c194e4c53ee22998ac9e3ac","project_uri":"https://rubygems.org/gems/png_conform","gem_uri":"https://rubygems.org/gems/png_conform-0.1.4.gem","homepage_uri":"https://github.com/claricle/png_conform","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/claricle/png_conform","bug_tracker_uri":null,"changelog_uri":"https://github.com/claricle/png_conform","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"bindata","requirements":"~> 2.5"},{"name":"lutaml-model","requirements":"~> 0.7"},{"name":"paint","requirements":"~> 2.3"},{"name":"thor","requirements":"~> 1.4"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/claricle/png_conform"}