{"gems":{"name":"tuile","downloads":1362,"version":"0.8.0","version_created_at":"2026-06-11T13:34:26.113Z","version_downloads":57,"platform":"ruby","authors":"Martin Vysny","info":"Tuile is a small TUI framework built on top of the TTY toolkit. It models\nthe terminal as a tree of components (windows, lists, text fields, popups)\nwith an invalidation-based repaint model and a single-threaded event queue,\nso apps don't have to think about locking. The name is French for \"roof\ntile\" — a small piece that composes into a larger whole.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mvysny/tuile","changelog_uri":"https://github.com/mvysny/tuile/blob/master/CHANGELOG.md","rubygems_mfa_required":"true"},"yanked":false,"sha":"d16d7907ad5463a8c6412fc899d7c4791e057596b42f9c8db305f9c6bd543d6c","spec_sha":"3fa05ad2ccac0f62784dcc181e924d1d99949dd5a8708baf2b4e0304f1830698","project_uri":"https://rubygems.org/gems/tuile","gem_uri":"https://rubygems.org/gems/tuile-0.8.0.gem","homepage_uri":"https://github.com/mvysny/tuile","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":"https://github.com/mvysny/tuile/blob/master/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"concurrent-ruby","requirements":"~> 1.3"},{"name":"logger","requirements":"~> 1.7"},{"name":"tty-cursor","requirements":"~> 0.7"},{"name":"tty-screen","requirements":"~> 0.8"},{"name":"unicode-display_width","requirements":">= 2.6, < 4.0"},{"name":"zeitwerk","requirements":"~> 2.7"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mvysny/tuile"}