{"gems":{"name":"tuile","downloads":250,"version":"0.2.0","version_created_at":"2026-05-15T09:56:34.168Z","version_downloads":37,"platform":"ruby","authors":"Martin Vysny","info":"Tuile is a small TUI framework built on top of the TTY toolkit. It models\nthe terminal as a tree of components (windows, lists, text fields, popups)\nwith an invalidation-based repaint model and a single-threaded event queue,\nso apps don't have to think about locking. The name is French for \"roof\ntile\" — a small piece that composes into a larger whole.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mvysny/tuile","changelog_uri":"https://github.com/mvysny/tuile/blob/master/CHANGELOG.md","rubygems_mfa_required":"true"},"yanked":false,"sha":"54b463cae9424c06138f9f4fa9c3b2d716823910886072d1a80f40e4d47911c8","spec_sha":"e04f4ef7d2a111f0decc7847fead00d4fd3c325060fc54c42198454dcb06a284","project_uri":"https://rubygems.org/gems/tuile","gem_uri":"https://rubygems.org/gems/tuile-0.2.0.gem","homepage_uri":"https://github.com/mvysny/tuile","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":"https://github.com/mvysny/tuile/blob/master/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"concurrent-ruby","requirements":"~> 1.3"},{"name":"logger","requirements":"~> 1.7"},{"name":"rainbow","requirements":"~> 3.1"},{"name":"tty-cursor","requirements":"~> 0.7"},{"name":"tty-screen","requirements":"~> 0.8"},{"name":"unicode-display_width","requirements":">= 2.6, < 4.0"},{"name":"zeitwerk","requirements":"~> 2.7"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mvysny/tuile"}