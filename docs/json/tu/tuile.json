{"gems":{"name":"tuile","downloads":1217,"version":"0.7.0","version_created_at":"2026-06-09T07:36:03.844Z","version_downloads":55,"platform":"ruby","authors":"Martin Vysny","info":"Tuile is a small TUI framework built on top of the TTY toolkit. It models\nthe terminal as a tree of components (windows, lists, text fields, popups)\nwith an invalidation-based repaint model and a single-threaded event queue,\nso apps don't have to think about locking. The name is French for \"roof\ntile\" — a small piece that composes into a larger whole.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/mvysny/tuile","changelog_uri":"https://github.com/mvysny/tuile/blob/master/CHANGELOG.md","rubygems_mfa_required":"true"},"yanked":false,"sha":"441a1b4af08740a711b94045166498b6ef343513687e978dbadf5e4806c56434","spec_sha":"e8332d5722fabccecd32f0ae5872ade13e9c4078a8a20542111c89207ba7f1ab","project_uri":"https://rubygems.org/gems/tuile","gem_uri":"https://rubygems.org/gems/tuile-0.7.0.gem","homepage_uri":"https://github.com/mvysny/tuile","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":"https://github.com/mvysny/tuile/blob/master/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"concurrent-ruby","requirements":"~> 1.3"},{"name":"logger","requirements":"~> 1.7"},{"name":"tty-cursor","requirements":"~> 0.7"},{"name":"tty-screen","requirements":"~> 0.8"},{"name":"unicode-display_width","requirements":">= 2.6, < 4.0"},{"name":"zeitwerk","requirements":"~> 2.7"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/mvysny/tuile"}