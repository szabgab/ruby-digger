{"gems":{"name":"omq-cli","downloads":4188,"version":"0.15.2","version_created_at":"2026-04-15T18:33:02.105Z","version_downloads":31,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstd compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"3a19e7fc5c008ecd2d750cf8b099b70774f854b9ec6d631344e1bad82dc7d666","spec_sha":"d09a7a180510a02c8f5442c6f8557cef50f4eaa1a51e66c42d1c95e22bad4c81","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.15.2.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.15.2","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.22"},{"name":"omq-ffi","requirements":"~> 0.2"},{"name":"omq-rfc-channel","requirements":"~> 0.2"},{"name":"omq-rfc-clientserver","requirements":"~> 0.2"},{"name":"omq-rfc-p2p","requirements":"~> 0.2"},{"name":"omq-rfc-radiodish","requirements":"~> 0.2"},{"name":"omq-rfc-scattergather","requirements":"~> 0.2"},{"name":"omq-rfc-zstd","requirements":"~> 0.3"},{"name":"rbnacl","requirements":"~> 7.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}