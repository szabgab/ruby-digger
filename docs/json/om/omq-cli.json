{"gems":{"name":"omq-cli","downloads":6624,"version":"0.18.0","version_created_at":"2026-05-11T10:30:20.679Z","version_downloads":28,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstd/LZ4 compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"39a2027f4eeecbd35df5ad4469cd0ce2518f5f9ffc9812b086e14a4f5fba1f19","spec_sha":"82cb3c887a65170c1eeb106c28bd6bf3a50f3ff55f0f9535e0bba6705571dc86","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.18.0.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.18.0","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"ffi","requirements":">= 0"},{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.27"},{"name":"omq-lz4","requirements":"~> 0.3"},{"name":"omq-zstd","requirements":"~> 0.4"},{"name":"rbnacl","requirements":"~> 7.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}