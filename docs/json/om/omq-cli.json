{"gems":{"name":"omq-cli","downloads":3846,"version":"0.15.1","version_created_at":"2026-04-14T12:58:14.644Z","version_downloads":18,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstd compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"17950311c92b5f94c31231858fe87cde15da1d33c9176fb28a7ae17b05b4a391","spec_sha":"4192a54715d8819012482f2c035f922b26a38d16d9f9af8a5a7d7ad012afdeb4","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.15.1.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.15.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.19, >= 0.19.3"},{"name":"omq-ffi","requirements":"~> 0.2"},{"name":"omq-rfc-channel","requirements":"~> 0.1"},{"name":"omq-rfc-clientserver","requirements":"~> 0.1"},{"name":"omq-rfc-p2p","requirements":"~> 0.1"},{"name":"omq-rfc-radiodish","requirements":"~> 0.1"},{"name":"omq-rfc-scattergather","requirements":"~> 0.1"},{"name":"omq-rfc-zstd","requirements":"~> 0.2"},{"name":"rbnacl","requirements":"~> 7.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}