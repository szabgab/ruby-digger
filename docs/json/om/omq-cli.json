{"gems":{"name":"omq-cli","downloads":2107,"version":"0.12.1","version_created_at":"2026-04-10T21:03:13.119Z","version_downloads":0,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), LZ4 compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"bdd0079f645b2fe32f9c9affef06382aa80f9e5625ff85ac5e6d723c1d60ccbc","spec_sha":"dd80963a3def1c23109d4621428d5c99d0cab9e8f57480a1f5a9d8fdf57205a8","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.12.1.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.12.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.17, >= 0.17.8"},{"name":"omq-ffi","requirements":"~> 0.2"},{"name":"omq-rfc-channel","requirements":"~> 0.1"},{"name":"omq-rfc-clientserver","requirements":"~> 0.1"},{"name":"omq-rfc-p2p","requirements":"~> 0.1"},{"name":"omq-rfc-radiodish","requirements":"~> 0.1"},{"name":"omq-rfc-scattergather","requirements":"~> 0.1"},{"name":"rbnacl","requirements":"~> 7.0"},{"name":"rlz4","requirements":"~> 0.1"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}