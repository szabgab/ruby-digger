{"gems":{"name":"omq-cli","downloads":3331,"version":"0.14.8","version_created_at":"2026-04-13T23:04:52.334Z","version_downloads":5,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstd compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"ea3002612b3199aae07aeb01c05e94d9e71169abd97444f98be5f79fb3de40a9","spec_sha":"f5ec16b45c5542665be53fefe2033c7f6a5ffd66039c616d818ef884f9c28f5c","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.14.8.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.14.8","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.19, >= 0.19.3"},{"name":"omq-ffi","requirements":"~> 0.2"},{"name":"omq-rfc-channel","requirements":"~> 0.1"},{"name":"omq-rfc-clientserver","requirements":"~> 0.1"},{"name":"omq-rfc-p2p","requirements":"~> 0.1"},{"name":"omq-rfc-radiodish","requirements":"~> 0.1"},{"name":"omq-rfc-scattergather","requirements":"~> 0.1"},{"name":"omq-rfc-zstd","requirements":"~> 0.1"},{"name":"rbnacl","requirements":"~> 7.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}