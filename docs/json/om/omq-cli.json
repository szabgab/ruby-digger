{"gems":{"name":"omq-cli","downloads":4322,"version":"0.15.3","version_created_at":"2026-04-16T10:22:47.049Z","version_downloads":1,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstd compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"980a078878be7adff2f4a74f73476a5cc7dc128df889e01d67c32f55cdf18a71","spec_sha":"f5141db3a83c96eceb66b45db0d73dee1bfbeca944c49ff9d8776056724d4f9a","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.15.3.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.15.3","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.22"},{"name":"omq-ffi","requirements":"~> 0.2"},{"name":"omq-rfc-channel","requirements":"~> 0.2"},{"name":"omq-rfc-clientserver","requirements":"~> 0.2"},{"name":"omq-rfc-p2p","requirements":"~> 0.2"},{"name":"omq-rfc-radiodish","requirements":"~> 0.2"},{"name":"omq-rfc-scattergather","requirements":"~> 0.2"},{"name":"omq-rfc-zstd","requirements":"~> 0.3"},{"name":"rbnacl","requirements":"~> 7.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}