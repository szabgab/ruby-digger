{"gems":{"name":"omq-cli","downloads":816,"version":"0.7.1","version_created_at":"2026-04-07T18:20:15.247Z","version_downloads":31,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstandard compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"2f9182f5b3c5bcd82d0a76d244ffe7eee4b1844fd4f804bcb6b19d4220e5245a","spec_sha":"f416a87a5a0449e0343e7047ef263123f153632f01f0fccf3dcb9151035b2a61","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.7.1.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.7.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.15, >= 0.15.2"},{"name":"omq-rfc-channel","requirements":"~> 0.1"},{"name":"omq-rfc-clientserver","requirements":"~> 0.1"},{"name":"omq-rfc-p2p","requirements":"~> 0.1"},{"name":"omq-rfc-radiodish","requirements":"~> 0.1"},{"name":"omq-rfc-scattergather","requirements":"~> 0.1"},{"name":"rbnacl","requirements":"~> 7.0"},{"name":"zstd-ruby","requirements":">= 0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}