{"gems":{"name":"omq-cli","downloads":3437,"version":"0.14.9","version_created_at":"2026-04-13T23:37:53.242Z","version_downloads":26,"platform":"ruby","authors":"Patrik Wenger","info":"Command-line tool for sending and receiving ZeroMQ messages on any socket type (REQ/REP, PUB/SUB, PUSH/PULL, DEALER/ROUTER, and all draft types). Supports Ruby eval (-e/-E), script handlers (-r), pipe virtual socket with Ractor parallelism, multiple formats (ASCII, JSON Lines, msgpack, Marshal), Zstd compression, and CURVE encryption. Like nngcat from libnng, but with Ruby superpowers.","licenses":["ISC"],"metadata":{},"yanked":false,"sha":"9519e588dfa3e86905723fdb2169611bc18e0ac893678d7870b34978ea33ddbd","spec_sha":"f574c6cac25b051cf4c8da4001ead3add377efedc6474541928552c943d80aa1","project_uri":"https://rubygems.org/gems/omq-cli","gem_uri":"https://rubygems.org/gems/omq-cli-0.14.9.gem","homepage_uri":"https://github.com/paddor/omq-cli","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/omq-cli/0.14.9","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"msgpack","requirements":">= 0"},{"name":"omq","requirements":"~> 0.19, >= 0.19.3"},{"name":"omq-ffi","requirements":"~> 0.2"},{"name":"omq-rfc-channel","requirements":"~> 0.1"},{"name":"omq-rfc-clientserver","requirements":"~> 0.1"},{"name":"omq-rfc-p2p","requirements":"~> 0.1"},{"name":"omq-rfc-radiodish","requirements":"~> 0.1"},{"name":"omq-rfc-scattergather","requirements":"~> 0.1"},{"name":"omq-rfc-zstd","requirements":"~> 0.1"},{"name":"rbnacl","requirements":"~> 7.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/paddor/omq-cli"}