{"gems":{"name":"ruby_cms","downloads":4399,"version":"1.1.1","version_created_at":"2026-06-29T14:15:08.947Z","version_downloads":95,"platform":"ruby","authors":"Codebyjob","info":"RubyCMS is an install-only generator: `ruby_cms install` copies admin\ncontrollers, views, models, helpers, and JavaScript for the modules you\nselect into your host app, which then runs entirely on the copied code (no\nruntime engine to mount). `ruby_cms update`/`sync` keep the copied files in\nstep with the gem templates. Modules include:\n\n- Visual editor with inline editing\n- Content blocks with rich text support\n- Permission-based access control\n- User management & passkey (WebAuthn) login\n- Analytics, audit log, media library, redirects, and more\n","licenses":[],"metadata":{"homepage_uri":"https://github.com/jobhammer00/ruby_cms","changelog_uri":"https://github.com/jobhammer00/ruby_cms/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/jobhammer00/ruby_cms","rubygems_mfa_required":"true"},"yanked":false,"sha":"25083cb2f3f1ce079adafa9dcf0d8ed0c5f5a248ac78351a0bbdfeef0fcfb216","spec_sha":"2087b3b6388753c4b4fa67d3f9344cbe2309d8582597efaa1cc68c08bcf3caf6","project_uri":"https://rubygems.org/gems/ruby_cms","gem_uri":"https://rubygems.org/gems/ruby_cms-1.1.1.gem","homepage_uri":"https://github.com/jobhammer00/ruby_cms","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/jobhammer00/ruby_cms","bug_tracker_uri":null,"changelog_uri":"https://github.com/jobhammer00/ruby_cms/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"actiontext","requirements":">= 7.1"},{"name":"ahoy_matey","requirements":">= 5.0"},{"name":"noticed","requirements":">= 2.6"},{"name":"pagy","requirements":">= 43.0"},{"name":"pg_search","requirements":">= 2.3"},{"name":"rails","requirements":">= 7.1"},{"name":"thor","requirements":">= 1.3"},{"name":"tty-prompt","requirements":">= 0.23"}]}},"vcs_name":"GitHub","