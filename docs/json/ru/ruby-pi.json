{"gems":{"name":"ruby-pi","downloads":531,"version":"0.1.5","version_created_at":"2026-04-30T18:17:45.965Z","version_downloads":4,"platform":"ruby","authors":"RubyPi Contributors","info":"RubyPi is a minimal, composable AI agent harness for Ruby. Build production-ready LLM agents and AI agents with a unified provider interface across OpenAI, Anthropic Claude, and Google Gemini, plus first-class support for tool calling (function calling), streaming responses, automatic retries, provider fallback, context compaction, and a think-act-observe agent loop. Anti-framework design — small, idiomatic, and explicit. Ideal for building autonomous AI agents, ReAct agents, tool-using LLM agents, and chatbots in Ruby.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/ejwhite7/ruby-pi","changelog_uri":"https://github.com/ejwhite7/ruby-pi/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/ejwhite7/ruby-pi","rubygems_mfa_required":"true"},"yanked":false,"sha":"3a5b304b89b58bc27326da7fa99d824760814d0ec9fd0872074c916b6c149688","spec_sha":"3bac8503e2c1cd78f425f8f70f7f6b9aa2b8bfdd5867fb7330420f0f578132a5","project_uri":"https://rubygems.org/gems/ruby-pi","gem_uri":"https://rubygems.org/gems/ruby-pi-0.1.5.gem","homepage_uri":"https://github.com/ejwhite7/ruby-pi","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/ejwhite7/ruby-pi","bug_tracker_uri":null,"changelog_uri":"https://github.com/ejwhite7/ruby-pi/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"rake","requirements":"~> 13.0"},{"name":"rspec","requirements":"~> 3.12"},{"name":"webmock","requirements":"~> 3.18"}],"runtime":[{"name":"concurrent-ruby","requirements":"~> 1.2"},{"name":"faraday","requirements":"~> 2.0"},{"name":"faraday-net_http","requirements":"~> 3.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/ejwhite7/ruby-pi"}