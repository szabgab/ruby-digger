{"gems":{"name":"ruby_dsp","downloads":407,"version":"0.0.5","version_created_at":"2026-03-09T17:39:34.683Z","version_downloads":33,"platform":"ruby","authors":"Radek C.","info":"RubyDSP is a hobby project exploring C++ extensions via Rice to bring faster audio processing to Ruby. Powered by miniaudio, it features a zero-dependency build and supports basic format-agnostic loading (WAV, MP3, FLAC), WAV export, and time-domain manipulation (resampling, padding, fades, RMS). It is very much in early development, so expect API changes and absolutely no warranties!","licenses":["MIT"],"metadata":{},"yanked":false,"sha":"abeda979ab61be6c7e7705f0410e99167ec6a9dafffe5f1a804dc62a65c2295f","spec_sha":"39f1312de112581ba1bd297af821a3b1923aca9d2c0ef879d828bf915643bf9e","project_uri":"https://rubygems.org/gems/ruby_dsp","gem_uri":"https://rubygems.org/gems/ruby_dsp-0.0.5.gem","homepage_uri":"https://github.com/cichrrad/rubyDSP","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/ruby_dsp/0.0.5","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":"~> 6.0"},{"name":"rack","requirements":"~> 3.2"},{"name":"rackup","requirements":"~> 2.3"},{"name":"rake","requirements":"~> 13.0"},{"name":"rake-compiler","requirements":"~> 1.3"},{"name":"rubocop","requirements":"~> 1.85"},{"name":"webrick","requirements":"~> 1.9"},{"name":"yard","requirements":"~> 0.9"}],"runtime":[{"name":"rice","requirements":"~> 4.11.2"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/cichrrad/rubyDSP"}