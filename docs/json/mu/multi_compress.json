{"gems":{"name":"multi_compress","downloads":2823,"version":"0.6.0","version_created_at":"2026-07-06T11:33:57.268Z","version_downloads":191,"platform":"ruby","authors":"Roman Haydarov","info":"Unified C-extension gem for zstd, lz4, and brotli compression. One-shot, streaming, IO wrappers, dictionary support. Fiber-friendly: cooperates with Fiber::Scheduler (async, falcon) so CPU-heavy compression never blocks the event loop. Ships vendored sources — no system libraries required.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/roman-haidarov/multi_compress","changelog_uri":"https://github.com/roman-haidarov/multi_compress/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/roman-haidarov/multi_compress"},"yanked":false,"sha":"11e6845909782f5a1c571a19450be9daebb5aa4fd5f53ec071b22a258932a3f7","spec_sha":"f04a1c9a06857da5b4198aa4e7a39e5de6a24b4008f5a45a2b9884e927063e80","project_uri":"https://rubygems.org/gems/multi_compress","gem_uri":"https://rubygems.org/gems/multi_compress-0.6.0.gem","homepage_uri":"https://github.com/roman-haidarov/multi_compress","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/roman-haidarov/multi_compress","bug_tracker_uri":null,"changelog_uri":"https://github.com/roman-haidarov/multi_compress/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"bundler","requirements":"~> 2.0"},{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":"~> 13.0"},{"name":"rake-compiler","requirements":"~> 1.2"}],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/roman-haidarov/multi_compress"}