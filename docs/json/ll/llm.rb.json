{"gems":{"name":"llm.rb","downloads":90855,"version":"11.3.1","version_created_at":"2026-06-21T13:21:38.877Z","version_downloads":39,"platform":"ruby","authors":"Robert (0x1eef), Antar Azri, Rodrigo Serrano","info":"llm.rb is Ruby's capable AI runtime.\n\nIt runs on Ruby's standard library by default. loads optional pieces\nonly when needed, and offers a single runtime for providers, agents,\ntools, skills, MCP, A2A (Agent2Agent), RAG (vector stores & embeddings),\nstreaming, files, and persisted state. As a bonus, llm.rb is also available\nfor mruby.\n\nIt supports OpenAI, OpenAI-compatible endpoints, Anthropic, Google\nGemini, DeepSeek, xAI, Z.ai, AWS Bedrock, Ollama, and llama.cpp. It\nalso includes built-in ActiveRecord and Sequel support, plus concurrent\ntool execution through threads, tasks (via async gem), fibers, ractors,\nand fork (via xchan.rb gem).\n","licenses":["0BSD"],"metadata":{"homepage_uri":"https://r.uby.dev/llm/","changelog_uri":"https://r.uby.dev/api-docs/llm.rb/file.CHANGELOG.html","source_code_uri":"https://github.com/r-uby-dev/llm.rb","documentation_uri":"https://r.uby.dev/llm/"},"yanked":false,"sha":"867b3cac87eda857de98ccbb00519ce41a791fa9c9508e765e26ebf3acf818d0","spec_sha":"b4d4fbbc68ab8c38d8cb035c0df4bb1c2119f0d2682dd79bafdc78c478f56adc","project_uri":"https://rubygems.org/gems/llm.rb","gem_uri":"https://rubygems.org/gems/llm.rb-11.3.1.gem","homepage_uri":"https://r.uby.dev/llm/","wiki_uri":null,"documentation_uri":"https://r.uby.dev/llm/","mailing_list_uri":null,"source_code_uri":"https://github.com/r-uby-dev/llm.rb","bug_tracker_uri":null,"changelog_uri":"https://r.uby.dev/api-docs/llm.rb/file.CHANGELOG.html","funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"dotenv","requirements":"~> 2.8"},{"name":"irb","requirements":"~> 1.18"},{"name":"logger","requirements":"~> 1.7"},{"name":"net-http-persistent","requirements":"~> 4.0"},{"name":"opentelemetry-sdk","requirements":"~> 1.10"},