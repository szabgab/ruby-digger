{"gems":{"name":"llm.rb","downloads":85520,"version":"11.0.0","version_created_at":"2026-05-23T03:48:31.610Z","version_downloads":64,"platform":"ruby","authors":"Antar Azri, 0x1eef, Christos Maris, Rodrigo Serrano","info":"llm.rb is Ruby's most capable AI runtime.\n\nIt runs on Ruby's standard library by default. loads optional pieces\nonly when needed, and offers a single runtime for providers, agents,\ntools, skills, MCP, A2A (Agent2Agent), RAG (vector stores & embeddings),\nstreaming, files, and persisted state. As a bonus, llm.rb is also available\nfor mruby.\n\nIt supports OpenAI, OpenAI-compatible endpoints, Anthropic, Google\nGemini, DeepSeek, xAI, Z.ai, AWS Bedrock, Ollama, and llama.cpp. It\nalso includes built-in ActiveRecord and Sequel support, plus concurrent\ntool execution through threads, tasks (via async gem), fibers, ractors,\nand fork (via xchan.rb gem).\n","licenses":["0BSD"],"metadata":{"homepage_uri":"https://github.com/llmrb/llm.rb","changelog_uri":"https://0x1eef.github.io/x/llm.rb/file.CHANGELOG.html","source_code_uri":"https://github.com/llmrb/llm.rb","documentation_uri":"https://0x1eef.github.io/x/llm.rb"},"yanked":false,"sha":"25c0c04f7b91e6df3a16d5749bb4a0c3296516718e8aec8d6b521810c7ad7c22","spec_sha":"0d8871a72ef5edd1c940243a3d33504d27db419243ca3c43cfed31feebb67d65","project_uri":"https://rubygems.org/gems/llm.rb","gem_uri":"https://rubygems.org/gems/llm.rb-11.0.0.gem","homepage_uri":"https://github.com/llmrb/llm.rb","wiki_uri":null,"documentation_uri":"https://0x1eef.github.io/x/llm.rb","mailing_list_uri":null,"source_code_uri":"https://github.com/llmrb/llm.rb","bug_tracker_uri":null,"changelog_uri":"https://0x1eef.github.io/x/llm.rb/file.CHANGELOG.html","funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"dotenv","requirements":"~> 2.8"},{"name":"kramdown","requirements":"~> 2.4"},{"name":"logger","requirements":"~> 1.7"},{"name":"net-http-persistent","requirements":"~> 4.0"},{"name