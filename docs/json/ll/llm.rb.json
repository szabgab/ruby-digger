{"gems":{"name":"llm.rb","downloads":90067,"version":"11.3.0","version_created_at":"2026-06-14T21:34:45.584Z","version_downloads":219,"platform":"ruby","authors":"0x1eef (Robert), Antar Azri, Rodrigo Serrano, Christos Maris","info":"llm.rb is Ruby's most capable AI runtime.\n\nIt runs on Ruby's standard library by default. loads optional pieces\nonly when needed, and offers a single runtime for providers, agents,\ntools, skills, MCP, A2A (Agent2Agent), RAG (vector stores & embeddings),\nstreaming, files, and persisted state. As a bonus, llm.rb is also available\nfor mruby.\n\nIt supports OpenAI, OpenAI-compatible endpoints, Anthropic, Google\nGemini, DeepSeek, xAI, Z.ai, AWS Bedrock, Ollama, and llama.cpp. It\nalso includes built-in ActiveRecord and Sequel support, plus concurrent\ntool execution through threads, tasks (via async gem), fibers, ractors,\nand fork (via xchan.rb gem).\n","licenses":["0BSD"],"metadata":{"homepage_uri":"https://llmrb.github.io","changelog_uri":"https://0x1eef.github.io/x/llm.rb/file.CHANGELOG.html","source_code_uri":"https://github.com/llmrb/llm.rb","documentation_uri":"https://llmrb.github.io/llm.rb"},"yanked":false,"sha":"2052e3e388416424768fa458b781e70e6ad39c5a0e20a70925ea73ee1e26262c","spec_sha":"d63538660fbf5de5559e6c0b01d7a02c2c30009cc9bd63c678bb33fc9afaf332","project_uri":"https://rubygems.org/gems/llm.rb","gem_uri":"https://rubygems.org/gems/llm.rb-11.3.0.gem","homepage_uri":"https://llmrb.github.io","wiki_uri":null,"documentation_uri":"https://llmrb.github.io/llm.rb","mailing_list_uri":null,"source_code_uri":"https://github.com/llmrb/llm.rb","bug_tracker_uri":null,"changelog_uri":"https://0x1eef.github.io/x/llm.rb/file.CHANGELOG.html","funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"dotenv","requirements":"~> 2.8"},{"name":"irb","requirements":"~> 1.18"},{"name":"kramdown","requirements":"~> 2.4"},{"name":"logger","requirements":"~> 1.7"},{"name":"net-http-persistent","re