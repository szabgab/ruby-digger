{"gems":{"name":"llm.rb","downloads":80627,"version":"8.0.0","version_created_at":"2026-05-04T04:28:51.688Z","version_downloads":39,"platform":"ruby","authors":"Antar Azri, 0x1eef, Christos Maris, Rodrigo Serrano","info":"llm.rb is a lightweight runtime for building capable AI systems in Ruby.\nIt is not just an API wrapper. llm.rb gives you one runtime for providers,\ncontexts, agents, tools, MCP servers, streaming, schemas, files, and\npersisted state, so real systems can be built out of one coherent\nexecution model instead of a pile of adapters. It stays close to Ruby, runs\non the standard library by default, loads optional pieces only when needed,\nincludes built-in ActiveRecord support through acts_as_llm and\nacts_as_agent, includes built-in Sequel support through plugin :llm,\nand is designed for engineers who want control over long-lived,\ntool-capable, stateful AI workflows instead of just request/response\nhelpers.\n","licenses":["0BSD"],"metadata":{"homepage_uri":"https://github.com/llmrb/llm.rb","changelog_uri":"https://0x1eef.github.io/x/llm.rb/file.CHANGELOG.html","source_code_uri":"https://github.com/llmrb/llm.rb","documentation_uri":"https://0x1eef.github.io/x/llm.rb"},"yanked":false,"sha":"ece7d943ebb5515660181cf389729129ba4727983fef52078a1e5b201efbb190","spec_sha":"e61ce739fa471882977e0f0da7af2b7aca1801c89a0b3e9fd76c451a461f761c","project_uri":"https://rubygems.org/gems/llm.rb","gem_uri":"https://rubygems.org/gems/llm.rb-8.0.0.gem","homepage_uri":"https://github.com/llmrb/llm.rb","wiki_uri":null,"documentation_uri":"https://0x1eef.github.io/x/llm.rb","mailing_list_uri":null,"source_code_uri":"https://github.com/llmrb/llm.rb","bug_tracker_uri":null,"changelog_uri":"https://0x1eef.github.io/x/llm.rb/file.CHANGELOG.html","funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"dotenv","requirements":"~> 2.8"},{"name":"kramdown","requirements":"~> 2.4"},{"name":"logger","requirements":"~> 1.7"},{"name