{"gems":{"name":"jekyll-openapi","downloads":1109,"version":"0.2.0","version_created_at":"2026-07-09T10:26:59.851Z","version_downloads":98,"platform":"ruby","authors":"Sebastien Dumetz","info":"A (mostly) spec-compliant OpenAPI 3.1 toolkit for Jekyll and other\nLiquid-based static site generators: a navigable document model\n(dereferencing, operations, tags, parameters) and schema-to-text\nrenderers (TypeScript-like, XML), exposed as Liquid filters.\nSelf-registers when listed in a Jekyll site's plugins; usable as a\nplain library elsewhere. HTML rendering is left to the consumer.\n","licenses":["Apache-2.0"],"metadata":{},"yanked":false,"sha":"10ad55d49ccb6b8407473bbbfd4460ac01b44314db18e25a2cbf93f9929e4e1a","spec_sha":"e55320cffd41c081f509d0749dac0fc1574ff3b951d607eb5150ac85efb8a5ae","project_uri":"https://rubygems.org/gems/jekyll-openapi","gem_uri":"https://rubygems.org/gems/jekyll-openapi-0.2.0.gem","homepage_uri":"https://github.com/sdumetz/jekyll-openapi","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/jekyll-openapi/0.2.0","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"liquid","requirements":">= 4.0"},{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":"~> 13.0"}],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/sdumetz/jekyll-openapi"}