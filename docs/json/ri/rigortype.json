{"gems":{"name":"rigortype","downloads":9851,"version":"0.3.0","version_created_at":"2026-07-19T13:40:57.702Z","version_downloads":100,"platform":"ruby","authors":"Rigor contributors","info":"Rigor is a CLI-first static analyzer for Ruby applications that prioritizes type inference, clean application code, and zero runtime dependencies. Rigor is a standalone tool, not a library: install it independently rather than adding it to your application's Gemfile. It runs on Ruby 4.0 while your project keeps its own Ruby, and it reads your project as data rather than loading it, so a Gemfile entry only constrains your application's Ruby and dependency resolution. Installation channels (mise, asdf, gem install, container, Nix): https://github.com/rigortype/rigor/blob/master/docs/install.md","licenses":["MPL-2.0"],"metadata":{"bug_tracker_uri":"https://github.com/rigortype/rigor/issues","source_code_uri":"https://github.com/rigortype/rigor","documentation_uri":"https://github.com/rigortype/rigor/tree/master/docs","rubygems_mfa_required":"true"},"yanked":false,"sha":"148a3e4cebc088dc4f48636947dfa0c0e8c6645f9888b8074b12037bcc9e0fe0","spec_sha":"02f3f9c76a90f0fc50387c70744b4b39e3b3a0498bb85d633eff9ecf93ad02be","project_uri":"https://rubygems.org/gems/rigortype","gem_uri":"https://rubygems.org/gems/rigortype-0.3.0.gem","homepage_uri":"https://github.com/rigortype/rigor","wiki_uri":null,"documentation_uri":"https://github.com/rigortype/rigor/tree/master/docs","mailing_list_uri":null,"source_code_uri":"https://github.com/rigortype/rigor","bug_tracker_uri":"https://github.com/rigortype/rigor/issues","changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activesupport","requirements":">= 7.0, < 9.0"},{"name":"binpacker","requirements":">= 0.1.0, < 1.0"},{"name":"rack","requirements":">= 2.0, < 4.0"},{"name":"rake","requirements":">= 13.0, < 15.0"},{"name":"rbs-inline","requirements":">= 0.5, < 1.0"},{"name":"rspec","requirements":">= 3.13, < 4.0"},{"name":"rub