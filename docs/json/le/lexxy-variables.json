{"gems":{"name":"lexxy-variables","downloads":2067,"version":"0.0.5","version_created_at":"2026-07-19T21:27:06.522Z","version_downloads":96,"platform":"ruby","authors":"Andrew Quinn","info":"Insert and safely resolve variables in Lexxy rich text. The gem gives you an\neditor button (and a `{{` prompt) for inserting variables, each stored as an\nAction Text attachment chip rather than literal markup. `with_variables`\nresolves the chips and returns plain Action Text content. Register new chip types\nwith `register_attachment`. A :text chip resolves to an escaped string, an\n:html chip splices rich content in before sanitization. Liquid is optional.\nThe default renderer is plain, injection-safe string substitution and pulls\nin no template engine.\n","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","source_code_uri":"https://github.com/anquinn/lexxy-variables"},"yanked":false,"sha":"5b59ebe5a9828ff7bafbab783be950a3bf6d4cad2f6aba6686c96a793e83eaeb","spec_sha":"0591d9658b839edfef360ffbd32ac6c5a86a5ccf6c356fbb12f983f51aa733b8","project_uri":"https://rubygems.org/gems/lexxy-variables","gem_uri":"https://rubygems.org/gems/lexxy-variables-0.0.5.gem","homepage_uri":"https://github.com/anquinn/lexxy-variables","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/anquinn/lexxy-variables","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"liquid","requirements":">= 5.0"},{"name":"minitest","requirements":">= 5.0"}],"runtime":[{"name":"actiontext","requirements":">= 8.0"},{"name":"actionview","requirements":">= 8.0"},{"name":"activesupport","requirements":">= 8.0"},{"name":"nokogiri","requirements":">= 1.15"},{"name":"railties","requirements":">= 8.0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/anquinn/lexxy-variables"}