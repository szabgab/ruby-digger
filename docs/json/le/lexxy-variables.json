{"gems":{"name":"lexxy-variables","downloads":537,"version":"0.0.2","version_created_at":"2026-07-07T21:33:39.520Z","version_downloads":116,"platform":"ruby","authors":"Andrew Quinn","info":"Insert and safely resolve variables in Lexxy rich text. The gem gives you an\neditor button (and a `{{` prompt) for inserting variables, each stored as an\nAction Text attachment chip rather than literal markup, and resolves each chip\nto its value at render time. Register new chip types with `register_attachment`:\na :value chip resolves to an escaped string, a :fragment chip splices rich\ncontent in before sanitization. Liquid is optional. The default renderer is\nplain, injection-safe string substitution and pulls in no template engine.\n","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","source_code_uri":"https://github.com/anquinn/lexxy-variables"},"yanked":false,"sha":"6cc3b1fd4935683f4f1b767282501e41e40e5ca1cc138b81a012e798879b063c","spec_sha":"ccd4478556c0a87557e13570d25f3214429702ff38b478bc48d7fa079aeabd59","project_uri":"https://rubygems.org/gems/lexxy-variables","gem_uri":"https://rubygems.org/gems/lexxy-variables-0.0.2.gem","homepage_uri":"https://github.com/anquinn/lexxy-variables","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/anquinn/lexxy-variables","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"liquid","requirements":">= 5.0"},{"name":"minitest","requirements":">= 5.0"}],"runtime":[{"name":"actiontext","requirements":">= 8.0"},{"name":"actionview","requirements":">= 8.0"},{"name":"activesupport","requirements":">= 8.0"},{"name":"nokogiri","requirements":">= 1.15"},{"name":"railties","requirements":">= 8.0"}]}},