{"gems":{"name":"lexxy-variables","downloads":1055,"version":"0.0.3","version_created_at":"2026-07-13T13:00:52.645Z","version_downloads":66,"platform":"ruby","authors":"Andrew Quinn","info":"Insert and safely resolve variables in Lexxy rich text. The gem gives you an\neditor button (and a `{{` prompt) for inserting variables, each stored as an\nAction Text attachment chip rather than literal markup, and resolves each chip\nto its value at render time. Register new chip types with `register_attachment`:\na :value chip resolves to an escaped string, a :fragment chip splices rich\ncontent in before sanitization. Liquid is optional. The default renderer is\nplain, injection-safe string substitution and pulls in no template engine.\n","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","source_code_uri":"https://github.com/anquinn/lexxy-variables"},"yanked":false,"sha":"ed12e9faead859b24ffd6b1638450643f694d72221ae063a5c2c81fdf881642c","spec_sha":"e3d5f7c9260f8e4b23aaf6f110d1759446fde6e3a50250ca5d98e72fb5c185db","project_uri":"https://rubygems.org/gems/lexxy-variables","gem_uri":"https://rubygems.org/gems/lexxy-variables-0.0.3.gem","homepage_uri":"https://github.com/anquinn/lexxy-variables","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/anquinn/lexxy-variables","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"liquid","requirements":">= 5.0"},{"name":"minitest","requirements":">= 5.0"}],"runtime":[{"name":"actiontext","requirements":">= 8.0"},{"name":"actionview","requirements":">= 8.0"},{"name":"activesupport","requirements":">= 8.0"},{"name":"nokogiri","requirements":">= 1.15"},{"name":"railties","requirements":">= 8.0"}]}},