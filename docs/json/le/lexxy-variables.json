{"gems":{"name":"lexxy-variables","downloads":1110,"version":"0.0.4","version_created_at":"2026-07-14T00:17:24.636Z","version_downloads":3,"platform":"ruby","authors":"Andrew Quinn","info":"Insert and safely resolve variables in Lexxy rich text. The gem gives you an\neditor button (and a `{{` prompt) for inserting variables, each stored as an\nAction Text attachment chip rather than literal markup, and resolves each chip\nto its value at render time. Register new chip types with `register_attachment`:\na :value chip resolves to an escaped string, a :fragment chip splices rich\ncontent in before sanitization. Liquid is optional. The default renderer is\nplain, injection-safe string substitution and pulls in no template engine.\n","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","source_code_uri":"https://github.com/anquinn/lexxy-variables"},"yanked":false,"sha":"b9ff2d6a359ce6f88dd160d357de110b8be9fd0a8a7ccafd090fb42e92d9f3a5","spec_sha":"fc02c8f2c6aceedcd3ad53ec4ed7fd26adbc7ef5835a7aaf44c0c589869c54c4","project_uri":"https://rubygems.org/gems/lexxy-variables","gem_uri":"https://rubygems.org/gems/lexxy-variables-0.0.4.gem","homepage_uri":"https://github.com/anquinn/lexxy-variables","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/anquinn/lexxy-variables","bug_tracker_uri":"https://github.com/anquinn/lexxy-variables/issues","changelog_uri":"https://github.com/anquinn/lexxy-variables/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"liquid","requirements":">= 5.0"},{"name":"minitest","requirements":">= 5.0"}],"runtime":[{"name":"actiontext","requirements":">= 8.0"},{"name":"actionview","requirements":">= 8.0"},{"name":"activesupport","requirements":">= 8.0"},{"name":"nokogiri","requirements":">= 1.15"},{"name":"railties","requirements":">= 8.0"}]}},"