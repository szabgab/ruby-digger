{"gems":{"name":"leakferret","downloads":1309,"version":"0.1.14","version_created_at":"2026-06-03T10:24:13.388Z","version_downloads":38,"platform":"ruby","authors":"Maria Khan","info":"Context-aware secret scanning for Ruby projects. A thin wrapper around the\nnative leakferret binary (written in Rust): it finds hardcoded secrets,\nconfirms which ones are actually live by calling the provider, and rewrites\nthem to read from environment variables instead. The platform binary is\ndownloaded automatically on first use, so no Rust toolchain is required.\n\nThe API exposes Leakferret.scan, Leakferret.verify, and Leakferret.rewrite\n(each returning Finding objects), plus a `leakferret` command-line tool.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/leakferrethq/leakferret-ruby","changelog_uri":"https://github.com/leakferrethq/leakferret-ruby/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/leakferrethq/leakferret-ruby","documentation_uri":"https://rubydoc.info/gems/leakferret","rubygems_mfa_required":"true"},"yanked":false,"sha":"6eca6823fe92641a9dfdcba8d61e34c98555e8c0613dbbdeb57ae236c333c4a2","spec_sha":"7b1f45a34d40f958ef03b1cd4b114d5b141301e53895c18c9e717734e25d22a6","project_uri":"https://rubygems.org/gems/leakferret","gem_uri":"https://rubygems.org/gems/leakferret-0.1.14.gem","homepage_uri":"https://github.com/leakferrethq/leakferret-ruby","wiki_uri":null,"documentation_uri":"https://rubydoc.info/gems/leakferret","mailing_list_uri":null,"source_code_uri":"https://github.com/leakferrethq/leakferret-ruby","bug_tracker_uri":null,"changelog_uri":"https://github.com/leakferrethq/leakferret-ruby/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/leakferrethq/leakferret-ruby"}