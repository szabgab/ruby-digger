{"gems":{"name":"shrine","downloads":17100461,"version":"3.8.0","version_created_at":"2026-06-24T21:03:02.906Z","version_downloads":50,"platform":"ruby","authors":"Janko Marohnić","info":"Shrine is a toolkit for file attachments in Ruby applications. It supports\nuploading, downloading, processing and deleting IO objects, backed by various\nstorage engines. It uses efficient streaming for low memory usage.\n\nShrine comes with a high-level interface for attaching uploaded files to\ndatabase records, saving their location and metadata to a database column, and\ntying them to record's lifecycle. It natively supports background jobs and\ndirect uploads for fully asynchronous user experience.\n","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/shrinerb/shrine/blob/master/CHANGELOG.md","bug_tracker_uri":"https://github.com/shrinerb/shrine/issues","source_code_uri":"https://github.com/shrinerb/shrine","mailing_list_uri":"https://discourse.shrinerb.com","documentation_uri":"https://shrinerb.com"},"yanked":false,"sha":"658cc1fe1c5ec836a6c10bace7f214313e7d878acea09b6b658fe15fa19ea109","spec_sha":"28433e6887c13f2bf16d5f0e2d85d3ff6f3e0b46da984286d4d6d140d0aab1a6","project_uri":"https://rubygems.org/gems/shrine","gem_uri":"https://rubygems.org/gems/shrine-3.8.0.gem","homepage_uri":"https://shrinerb.com","wiki_uri":null,"documentation_uri":"https://shrinerb.com","mailing_list_uri":"https://discourse.shrinerb.com","source_code_uri":"https://github.com/shrinerb/shrine","bug_tracker_uri":"https://github.com/shrinerb/shrine/issues","changelog_uri":"https://github.com/shrinerb/shrine/blob/master/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0.0"},{"name":"activesupport","requirements":"~> 8.0.0"},{"name":"aws-sdk-core","requirements":"~> 3.23"},{"name":"aws-sdk-s3","requirements":"~> 1.69"},{"name":"dry-monitor","requirements":">= 0"},{"name":"fastimage","requirements":">= 0"},{"name":"http-form_data","re