{"gems":{"name":"shrine","downloads":16872245,"version":"3.7.1","version_created_at":"2026-06-03T09:47:28.353Z","version_downloads":119,"platform":"ruby","authors":"Janko Marohnić","info":"Shrine is a toolkit for file attachments in Ruby applications. It supports\nuploading, downloading, processing and deleting IO objects, backed by various\nstorage engines. It uses efficient streaming for low memory usage.\n\nShrine comes with a high-level interface for attaching uploaded files to\ndatabase records, saving their location and metadata to a database column, and\ntying them to record's lifecycle. It natively supports background jobs and\ndirect uploads for fully asynchronous user experience.\n","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/shrinerb/shrine/blob/master/CHANGELOG.md","bug_tracker_uri":"https://github.com/shrinerb/shrine/issues","source_code_uri":"https://github.com/shrinerb/shrine","mailing_list_uri":"https://discourse.shrinerb.com","documentation_uri":"https://shrinerb.com"},"yanked":false,"sha":"963d44c0e7cab2abb71c5dd514ba5c62ab039c2a0ccdccebe0fbcd376274d747","spec_sha":"d2a3cbbb794fa642a7d5b50410bafefdcdac538669ff3563182903e4a679cd58","project_uri":"https://rubygems.org/gems/shrine","gem_uri":"https://rubygems.org/gems/shrine-3.7.1.gem","homepage_uri":"https://shrinerb.com","wiki_uri":null,"documentation_uri":"https://shrinerb.com","mailing_list_uri":"https://discourse.shrinerb.com","source_code_uri":"https://github.com/shrinerb/shrine","bug_tracker_uri":"https://github.com/shrinerb/shrine/issues","changelog_uri":"https://github.com/shrinerb/shrine/blob/master/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.1"},{"name":"activesupport","requirements":"~> 8.1"},{"name":"aws-sdk-core","requirements":"~> 3.23"},{"name":"aws-sdk-s3","requirements":"~> 1.69"},{"name":"dry-monitor","requirements":">= 0"},{"name":"fastimage","requirements":">= 0"},{"name":"http-form_data","requi