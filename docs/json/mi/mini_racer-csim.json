{"gems":{"name":"mini_racer-csim","downloads":675,"version":"0.21.1.5","version_created_at":"2026-06-08T07:39:24.970Z","version_downloads":0,"platform":"ruby","authors":"Keita Urashima, Sam Saffron","info":"A private fork of mini_racer (minimal embedded V8 for Ruby) adding browser-level behavior used by capybara-simulated: the V8 ES Module API, per-frame realms, realm reset, cross-process bytecode caching, an opt-in host namespace, and a batched module-graph loader with a URL module registry. These are niche browser-fidelity features; general users should use upstream mini_racer. It loads under its own `mini_racer_csim` require path and `MiniRacerCsim` namespace, so it never collides with upstream mini_racer in the same bundle.","licenses":["MIT"],"metadata":{"bug_tracker_uri":"https://github.com/ursm/mini_racer/issues","source_code_uri":"https://github.com/ursm/mini_racer/tree/main"},"yanked":false,"sha":"12a593578fe73741c254e4c3ace1b1c0b83dc0b06cce85f11987da28a7b27d74","spec_sha":"8e16cdb151b530692103b19077613df93f73176647e72ca1110a1cc41daa7f57","project_uri":"https://rubygems.org/gems/mini_racer-csim","gem_uri":"https://rubygems.org/gems/mini_racer-csim-0.21.1.5.gem","homepage_uri":"https://github.com/ursm/mini_racer","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/ursm/mini_racer/tree/main","bug_tracker_uri":"https://github.com/ursm/mini_racer/issues","changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activesupport","requirements":"> 6"},{"name":"bundler","requirements":">= 0"},{"name":"m","requirements":">= 0"},{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":">= 12.3.3"},{"name":"rake-compiler","requirements":">= 0"}],"runtime":[{"name":"libv8-node","requirements":"~> 24.12.0.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/ursm/mini_racer/tree/main"}