{"gems":{"name":"mini_racer-csim","downloads":610,"version":"0.21.1.4","version_created_at":"2026-06-08T05:08:35.527Z","version_downloads":19,"platform":"ruby","authors":"Keita Urashima, Sam Saffron","info":"A private fork of mini_racer (minimal embedded V8 for Ruby) adding browser-level behavior used by capybara-simulated: the V8 ES Module API, per-frame realms, realm reset, cross-process bytecode caching, an opt-in host namespace, and a batched module-graph loader with a URL module registry. These are niche browser-fidelity features; general users should use upstream mini_racer. It loads under its own `mini_racer_csim` require path and `MiniRacerCsim` namespace, so it never collides with upstream mini_racer in the same bundle.","licenses":["MIT"],"metadata":{"bug_tracker_uri":"https://github.com/ursm/mini_racer/issues","source_code_uri":"https://github.com/ursm/mini_racer/tree/main"},"yanked":false,"sha":"c9e58c36d2654fead938bb8bab71a18b31fef157273f43408b610d4d43962f7c","spec_sha":"3f1571650c091feb87930dd26cb8c95d78168389881a46ce04ed7900d7d091c4","project_uri":"https://rubygems.org/gems/mini_racer-csim","gem_uri":"https://rubygems.org/gems/mini_racer-csim-0.21.1.4.gem","homepage_uri":"https://github.com/ursm/mini_racer","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/ursm/mini_racer/tree/main","bug_tracker_uri":"https://github.com/ursm/mini_racer/issues","changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activesupport","requirements":"> 6"},{"name":"bundler","requirements":">= 0"},{"name":"m","requirements":">= 0"},{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":">= 12.3.3"},{"name":"rake-compiler","requirements":">= 0"}],"runtime":[{"name":"libv8-node","requirements":"~> 24.12.0.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/ursm/mini_racer/tree/main"}