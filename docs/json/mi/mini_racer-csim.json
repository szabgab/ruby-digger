{"gems":{"name":"mini_racer-csim","downloads":225,"version":"0.21.1.2","version_created_at":"2026-06-06T15:53:40.047Z","version_downloads":41,"platform":"ruby","authors":"Keita Urashima, Sam Saffron","info":"A private fork of mini_racer (minimal embedded V8 for Ruby) adding browser-level behavior used by capybara-simulated: the V8 ES Module API, cross-process bytecode caching, an opt-in host namespace, realm reset, and a batched module-graph loader with a URL module registry. These are niche browser-fidelity features; general users should use upstream mini_racer. The library is still required as `mini_racer` and exposes the `MiniRacer` module, so it stays a drop-in for code targeting mini_racer.","licenses":["MIT"],"metadata":{"bug_tracker_uri":"https://github.com/ursm/mini_racer/issues","source_code_uri":"https://github.com/ursm/mini_racer/tree/main"},"yanked":false,"sha":"1057df05523299990a2f16b92b6464cddc6a9c49b0bb8c2c6d518ae60cc59e29","spec_sha":"0dbcd71a714dbeb960449b1d0fe5bc7a67650567e23a0da0318669dcbf5d3c40","project_uri":"https://rubygems.org/gems/mini_racer-csim","gem_uri":"https://rubygems.org/gems/mini_racer-csim-0.21.1.2.gem","homepage_uri":"https://github.com/ursm/mini_racer","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/ursm/mini_racer/tree/main","bug_tracker_uri":"https://github.com/ursm/mini_racer/issues","changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activesupport","requirements":"> 6"},{"name":"bundler","requirements":">= 0"},{"name":"m","requirements":">= 0"},{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":">= 12.3.3"},{"name":"rake-compiler","requirements":">= 0"}],"runtime":[{"name":"libv8-node","requirements":"~> 24.12.0.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/ursm/mini_racer/tree/main"}