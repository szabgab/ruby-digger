{"gems":{"name":"spinel_kit","downloads":681,"version":"0.3.0","version_created_at":"2026-07-09T12:23:39.031Z","version_downloads":114,"platform":"ruby","authors":"Ori Pekelman","info":"SpinelKit consolidates the pure-Ruby shims that every Spinel-compiled\nproject would otherwise hand-roll and that Spinel (the Ruby->native AOT\ncompiler) does not provide: .git/HEAD provenance, URL percent-codec +\nquery parsing, a minimal levelled logger, and a hex digit/byte codec.\n(JSON left in 0.3.0: Spinel now bundles `json` as a require-gated stdlib\npackage, so consumers use JSON.parse/JSON.generate directly.) Pure Ruby,\nno native extension, no runtime dependencies -- it vendors cleanly via\nbundler-spinel. Pre-alpha.","licenses":["MIT"],"metadata":{"changelog_uri":"https://github.com/OriPekelman/spinelkit/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/OriPekelman/spinelkit/issues","source_code_uri":"https://github.com/OriPekelman/spinelkit","documentation_uri":"https://github.com/OriPekelman/spinelkit#readme","rubygems_mfa_required":"true"},"yanked":false,"sha":"b5e86c82be3c7e5ab3b246d1741a9826bb662e09e47841f7fba98b3fc43f81b4","spec_sha":"7f990e91b02b1fece1d79b5394f405dfa1d3408d7f12e91ed96586d34cf3599c","project_uri":"https://rubygems.org/gems/spinel_kit","gem_uri":"https://rubygems.org/gems/spinel_kit-0.3.0.gem","homepage_uri":"https://github.com/OriPekelman/spinelkit","wiki_uri":null,"documentation_uri":"https://github.com/OriPekelman/spinelkit#readme","mailing_list_uri":null,"source_code_uri":"https://github.com/OriPekelman/spinelkit","bug_tracker_uri":"https://github.com/OriPekelman/spinelkit/issues","changelog_uri":"https://github.com/OriPekelman/spinelkit/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/OriPekelman/spinelkit"}