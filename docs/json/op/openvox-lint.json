{"gems":{"name":"openvox-lint","downloads":1762,"version":"1.3.2","version_created_at":"2026-05-24T23:50:49.230Z","version_downloads":47,"platform":"ruby","authors":"Jerald Sheets","info":"openvox-lint is a modern style-guide linter for OpenVox and Puppet manifests.\nIt checks your .pp files against the OpenVox Language Style Guide (the\ncurrent canonical reference) and catches common errors, deprecated patterns\n(legacy facts, Hiera 3, import, etc.), strict-mode issues, and Puppet 8+ /\nOpenVox 8.x problems. Includes real --fix support for many checks.\n\nFully compatible with OpenVox 8.x and Puppet 8.x. Drop-in replacement for\nthe archived puppet-lint with better Ruby 2.5+ support and OpenVox-specific\nchecks.\n","licenses":["Apache-2.0"],"metadata":{"homepage_uri":"https://github.com/cvquesty/openvox-lint","changelog_uri":"https://github.com/cvquesty/openvox-lint/blob/development/CHANGELOG.md","bug_tracker_uri":"https://github.com/cvquesty/openvox-lint/issues","source_code_uri":"https://github.com/cvquesty/openvox-lint","rubygems_mfa_required":"true"},"yanked":false,"sha":"da176e0b3af276921f8f18737cb47bf15dc4beffa053c0f4caa43ed59cdf5527","spec_sha":"60f56a81ff0afaa4b00e088226a66d166554ee79f25e69df49510b2bbe3bf4a6","project_uri":"https://rubygems.org/gems/openvox-lint","gem_uri":"https://rubygems.org/gems/openvox-lint-1.3.2.gem","homepage_uri":"https://github.com/cvquesty/openvox-lint","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/cvquesty/openvox-lint","bug_tracker_uri":"https://github.com/cvquesty/openvox-lint/issues","changelog_uri":"https://github.com/cvquesty/openvox-lint/blob/development/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"rake","requirements":"~> 13.0"},{"name":"rspec","requirements":"~> 3.12"},{"name":"rubocop","requirements":"~> 1.50"}],"runtime":[]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/cvquesty/openvox-lint"}