{"gems":{"name":"daru_lite","downloads":3436,"version":"0.2.3","version_created_at":"2026-03-27T14:27:41.375Z","version_downloads":38,"platform":"ruby","authors":"Thomas Naude-Filonnière, Maxime Lasserre, Julie Thomas, Amar Slaoua, Mourtada Belhantri","info":"Daru (Data Analysis in RUby) is a library for analysis, manipulation and visualization\nof data. Daru works seamlessly accross interpreters and leverages interpreter-specific\noptimizations whenever they are available.\n\nIt is the default data storage gem for all the statsample gems (glm, timeseries, etc.)\nand can be used with many others like mixed_models, gnuplotrb and iruby.\n\nDaru Lite is a fork of Daru that aims to focus on data manipulation and stability.\n","licenses":["BSD-2-Clause"],"metadata":{},"yanked":false,"sha":"1ee0991e7300fe6fdb22dc3ced264a8dfc2b33bda12b094a92deff3e98c3005c","spec_sha":"3975519faf49b78c12d41c5c8bcd57af50e86b3e3a4929c5c4c197d3cd7ac6f1","project_uri":"https://rubygems.org/gems/daru_lite","gem_uri":"https://rubygems.org/gems/daru_lite-0.2.3.gem","homepage_uri":"https://github.com/pollandroll/daru","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/daru_lite/0.2.3","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"awesome_print","requirements":"~> 1.9.2"},{"name":"bundler","requirements":"~> 2.6"},{"name":"csv","requirements":"~> 3.3.4"},{"name":"debug","requirements":">= 1.0.0"},{"name":"distribution","requirements":"~> 0.8"},{"name":"matrix","requirements":"~> 0.4.2"},{"name":"nokogiri","requirements":"~> 1.18.0"},{"name":"prime","requirements":"~> 0.1.2"},{"name":"rake","requirements":"~> 13.0"},{"name":"rspec","requirements":"~> 3.11"},{"name":"rspec-its","requirements":"~> 2.0.0"},{"name":"rubocop","requirements":"~> 1.60"},{"name":"rubocop-performance","requirements":"~> 1.25.0"},{"name":"rubocop-rspec","require