{"gems":{"name":"daru_lite","downloads":3864,"version":"0.3.0","version_created_at":"2026-04-14T09:15:50.393Z","version_downloads":9,"platform":"ruby","authors":"Thomas Naude-Filonnière, Maxime Lasserre, Julie Thomas, Amar Slaoua, Mourtada Belhantri","info":"Daru (Data Analysis in RUby) is a library for analysis, manipulation and visualization\nof data. Daru works seamlessly accross interpreters and leverages interpreter-specific\noptimizations whenever they are available.\n\nIt is the default data storage gem for all the statsample gems (glm, timeseries, etc.)\nand can be used with many others like mixed_models, gnuplotrb and iruby.\n\nDaru Lite is a fork of Daru that aims to focus on data manipulation and stability.\n","licenses":["BSD-2-Clause"],"metadata":{},"yanked":false,"sha":"3a6a94c681de74397e8d8eca05f2b72bec79184e14b6820854cb2eeaaa0df9d0","spec_sha":"31eabdfff3300cc9dcc1b736d8e20fcaff12a1d8cc4c857920b9ac5d8c817b17","project_uri":"https://rubygems.org/gems/daru_lite","gem_uri":"https://rubygems.org/gems/daru_lite-0.3.0.gem","homepage_uri":"https://github.com/pollandroll/daru","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/daru_lite/0.3.0","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"awesome_print","requirements":"~> 1.9.2"},{"name":"bundler","requirements":"~> 2.6"},{"name":"csv","requirements":"~> 3.3.4"},{"name":"debug","requirements":">= 1.0.0"},{"name":"distribution","requirements":"~> 0.8"},{"name":"matrix","requirements":"~> 0.4.2"},{"name":"nokogiri","requirements":"~> 1.18.0"},{"name":"prime","requirements":"~> 0.1.2"},{"name":"rake","requirements":"~> 13.0"},{"name":"rspec","requirements":"~> 3.11"},{"name":"rspec-its","requirements":"~> 2.0.0"},{"name":"rubocop","requirements":"~> 1.86"},{"name":"rubocop-performance","requirements":"~> 1.25.0"},{"name":"rubocop-rspec","requirem