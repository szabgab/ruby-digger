{"gems":{"name":"daru_lite","downloads":4056,"version":"0.3.1","version_created_at":"2026-04-17T07:13:39.086Z","version_downloads":14,"platform":"ruby","authors":"Thomas Naude-Filonnière, Maxime Lasserre, Julie Thomas, Amar Slaoua, Mourtada Belhantri","info":"Daru (Data Analysis in RUby) is a library for analysis, manipulation and visualization\nof data. Daru works seamlessly accross interpreters and leverages interpreter-specific\noptimizations whenever they are available.\n\nIt is the default data storage gem for all the statsample gems (glm, timeseries, etc.)\nand can be used with many others like mixed_models, gnuplotrb and iruby.\n\nDaru Lite is a fork of Daru that aims to focus on data manipulation and stability.\n","licenses":["BSD-2-Clause"],"metadata":{},"yanked":false,"sha":"dc868a43f3a23f53eedd315b26e168755b1fda5f6817a27862567f5c13f842ef","spec_sha":"86009c694579c8a31c39657cbb370b844e4c7efecf280175911b12c76e025a0a","project_uri":"https://rubygems.org/gems/daru_lite","gem_uri":"https://rubygems.org/gems/daru_lite-0.3.1.gem","homepage_uri":"https://github.com/pollandroll/daru","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/daru_lite/0.3.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"activerecord","requirements":"~> 8.0"},{"name":"awesome_print","requirements":"~> 1.9.2"},{"name":"bundler","requirements":"~> 2.6"},{"name":"csv","requirements":"~> 3.3.4"},{"name":"debug","requirements":">= 1.0.0"},{"name":"distribution","requirements":"~> 0.8"},{"name":"matrix","requirements":"~> 0.4.2"},{"name":"nokogiri","requirements":"~> 1.18.0"},{"name":"prime","requirements":"~> 0.1.2"},{"name":"rake","requirements":"~> 13.0"},{"name":"rspec","requirements":"~> 3.11"},{"name":"rspec-its","requirements":"~> 2.0.0"},{"name":"rubocop","requirements":"~> 1.86"},{"name":"rubocop-performance","requirements":"~> 1.25.0"},{"name":"rubocop-rspec","require