{"gems":{"name":"relaton","downloads":688794,"version":"2.2.0.pre.alpha.1","version_created_at":"2026-06-26T16:34:03.501Z","version_downloads":0,"platform":"ruby","authors":"Ribose Inc.","info":"Relaton is the central database, registry, and cache for bibliographic\nreferences to technical standards in the Relaton/XML bibliographic\nmodel. It provides the Relaton::Db API, a plugin registry that lazily\nloads flavor gems (relaton-iso, relaton-ietf, etc.) on demand, and a\nfile-based cache for fetched references.\n\nInstalling this gem also pulls in every Relaton flavor plugin so you\ncan fetch references from any supported standards body out of the\nbox. The CLI (relaton-cli) is intentionally NOT a dependency —\ninstall it separately when you need command-line access.\n","licenses":["BSD-2-Clause"],"metadata":{"rubygems_mfa_required":"true"},"yanked":false,"sha":"acd12f3c2afad925dc6b334e4c73f24df1d2da8dffa890b5f58adde659a59dcf","spec_sha":"861ece6aaa302715fdc3bf23cb531e5fba806737e5e9fed542243c18f4d3252a","project_uri":"https://rubygems.org/gems/relaton","gem_uri":"https://rubygems.org/gems/relaton-2.2.0.pre.alpha.1.gem","homepage_uri":"https://github.com/relaton/relaton","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/relaton/2.2.0.pre.alpha.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"relaton-3gpp","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-bib","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-bipm","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-bsi","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-calconnect","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-ccsds","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-cen","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-cie","requirements":"~> 2.2.0.pre.alpha.1"},{"name":"relaton-core","requirements":"~> 2.2.0.pre.alpha.1"},{"