{"gems":{"name":"recursive-open-struct","downloads":68493813,"version":"2.1.1","version_created_at":"2026-04-19T00:49:47.031Z","version_downloads":45,"platform":"ruby","authors":"William (B.J.) Snow Orvis","info":"RecursiveOpenStruct is a subclass of OpenStruct. It differs from\nOpenStruct in that it allows nested hashes to be treated in a recursive\nfashion. For example:\n\n    ros = RecursiveOpenStruct.new({ :a => { :b => 'c' } })\n    ros.a.b # 'c'\n\nAlso, nested hashes can still be accessed as hashes:\n\n    ros.a_as_a_hash # { :b => 'c' }\n","licenses":["MIT"],"metadata":{},"yanked":false,"sha":"27da6192b803b618bd866eb6d7bb92b18f608ab6a71796522d9d890906a25392","spec_sha":"db6aaf17cb74f0420b2c80fd959f8ee2de67137b46e4581a93f4fd9d6f2ce7e3","project_uri":"https://rubygems.org/gems/recursive-open-struct","gem_uri":"https://rubygems.org/gems/recursive-open-struct-2.1.1.gem","homepage_uri":"https://github.com/aetherknight/recursive-open-struct","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/recursive-open-struct/2.1.1","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"bundler","requirements":">= 2"},{"name":"pry","requirements":">= 0"},{"name":"rake","requirements":"~> 13.4"},{"name":"rdoc","requirements":"~> 7.2"},{"name":"rspec","requirements":"~> 3.13"},{"name":"rubocop","requirements":"~> 1.86"},{"name":"rubocop-rake","requirements":"~> 0.7"},{"name":"rubocop-rspec","requirements":"~> 3.9"},{"name":"simplecov","requirements":">= 0"}],"runtime":[{"name":"ostruct","requirements":">= 0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/aetherknight/recursive-open-struct"}