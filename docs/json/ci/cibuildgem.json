{"gems":{"name":"cibuildgem","downloads":3662,"version":"0.3.0","version_created_at":"2026-03-27T14:18:45.918Z","version_downloads":0,"platform":"ruby","authors":"Shopify","info":"Gems with native extensions are the main bottleneck for a user when running `bundle install`.\nThis gem aims to provide the Ruby community an easy to opt-in and quick way to distribute their\ngems with precompiled binaries.\n\nThis toolchain works with a native CI based compilation approach using GitHub actions. It piggyback on\ntop of popular tools in the Ruby ecosystem that maintainers are used to such as Rake Compiler and ruby/setup-ruby.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/shopify/cibuildwheel","source_code_uri":"https://github.com/shopify/cibuildwheel","allowed_push_host":"https://rubygems.org"},"yanked":false,"sha":"cf038e8ab046a9531c2528243b4240827deb0a31e6061fe78d5bf26c7945ef20","spec_sha":"52baad9d57668cad3451c24b77bd26097f60b3aaf2b5eabb6703f1c5a024df41","project_uri":"https://rubygems.org/gems/cibuildgem","gem_uri":"https://rubygems.org/gems/cibuildgem-0.3.0.gem","homepage_uri":"https://github.com/shopify/cibuildwheel","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/shopify/cibuildwheel","bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"prism","requirements":">= 0"},{"name":"rake-compiler","requirements":">= 0"},{"name":"thor","requirements":">= 0"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/shopify/cibuildwheel"}