{"gems":{"name":"rangeable","downloads":165,"version":"2.0.0","version_created_at":"2026-05-10T07:15:29.018Z","version_downloads":40,"platform":"ruby","authors":"ZhgChgLi","info":"Rangeable is a language-neutral, generic, integer-coordinate closed-interval\nset container. It pairs hashable elements with their merged disjoint integer\nranges and answers three queries: by-element ranges, by-position active set,\nand by-range transition events. The Ruby reference implementation follows\nthe Rangeable RFC normatively, including idempotent containment fast-path,\nlazy boundary-event indexing, and first-insert deterministic ordering.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/ZhgChgLi/RubyRangeable","changelog_uri":"https://github.com/ZhgChgLi/RubyRangeable/blob/main/CHANGELOG.md","bug_tracker_uri":"https://github.com/ZhgChgLi/RubyRangeable/issues","source_code_uri":"https://github.com/ZhgChgLi/RubyRangeable","documentation_uri":"https://github.com/ZhgChgLi/RangeableRFC/blob/main/RFC.md","rubygems_mfa_required":"true"},"yanked":false,"sha":"aaddefeaec8fdb0b742284c1821a4fb0330bf9915cc0e79dc06f20c97a019446","spec_sha":"8cc236bfaf42029e28f29479ce043cfcbd2c8d9def42d074e3f51238d3c78b83","project_uri":"https://rubygems.org/gems/rangeable","gem_uri":"https://rubygems.org/gems/rangeable-2.0.0.gem","homepage_uri":"https://github.com/ZhgChgLi/RubyRangeable","wiki_uri":null,"documentation_uri":"https://github.com/ZhgChgLi/RangeableRFC/blob/main/RFC.md","mailing_list_uri":null,"source_code_uri":"https://github.com/ZhgChgLi/RubyRangeable","bug_tracker_uri":"https://github.com/ZhgChgLi/RubyRangeable/issues","changelog_uri":"https://github.com/ZhgChgLi/RubyRangeable/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":"~> 5.0"},{"name":"rake","requirements":"~> 13.0"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/ZhgChgLi/RubyRangeable"}