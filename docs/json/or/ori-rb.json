{"gems":{"name":"ori-rb","downloads":1023,"version":"0.4.8","version_created_at":"2026-03-19T22:59:08.267Z","version_downloads":5,"platform":"ruby","authors":"Jahfer Husain","info":"Ori is a library for Ruby that provides a robust set of primitives for building concurrent applications. The name comes from the Japanese word 折り \"ori\" meaning \"fold\", reflecting how concurrent operations interleave. Ori provides a set of primitives that allow you to build concurrent applications—that is, applications that interleave execution within a single thread—without blocking the entire Ruby interpreter for each task.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/jahfer/ori","changelog_uri":"https://github.com/jahfer/ori/releases","source_code_uri":"https://github.com/jahfer/ori"},"yanked":false,"sha":"16ef6d8b3ea826b490545939cc84cc06888a5974dee03aa0dfabf28bb20b60e9","spec_sha":"238e27f3d569fc2c63249646a1f77bec924d48dc8ef18ab501b2391d50327b3b","project_uri":"https://rubygems.org/gems/ori-rb","gem_uri":"https://rubygems.org/gems/ori-rb-0.4.8.gem","homepage_uri":"https://github.com/jahfer/ori","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/jahfer/ori","bug_tracker_uri":null,"changelog_uri":"https://github.com/jahfer/ori/releases","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"nio4r","requirements":"~> 2.7"},{"name":"zeitwerk","requirements":"~> 2.7.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/jahfer/ori"}