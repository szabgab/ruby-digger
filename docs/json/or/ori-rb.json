{"gems":{"name":"ori-rb","downloads":906,"version":"0.4.6","version_created_at":"2026-03-19T12:02:51.420Z","version_downloads":2,"platform":"ruby","authors":"Jahfer Husain","info":"Ori is a library for Ruby that provides a robust set of primitives for building concurrent applications. The name comes from the Japanese word 折り \"ori\" meaning \"fold\", reflecting how concurrent operations interleave. Ori provides a set of primitives that allow you to build concurrent applications—that is, applications that interleave execution within a single thread—without blocking the entire Ruby interpreter for each task.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/jahfer/ori","changelog_uri":"https://github.com/jahfer/ori/releases","source_code_uri":"https://github.com/jahfer/ori"},"yanked":false,"sha":"43f98b73810858c47ec83628a44eb6a399ab2b76ec9d42fae085c5136b528dad","spec_sha":"439d9f224c32fcb630cec69a4404c021fe18f7ece9c4b505f88e62257ae46b71","project_uri":"https://rubygems.org/gems/ori-rb","gem_uri":"https://rubygems.org/gems/ori-rb-0.4.6.gem","homepage_uri":"https://github.com/jahfer/ori","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/jahfer/ori","bug_tracker_uri":null,"changelog_uri":"https://github.com/jahfer/ori/releases","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"nio4r","requirements":"~> 2.7"},{"name":"zeitwerk","requirements":"~> 2.7.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/jahfer/ori"}