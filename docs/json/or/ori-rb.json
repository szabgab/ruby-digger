{"gems":{"name":"ori-rb","downloads":716,"version":"0.4.4","version_created_at":"2026-03-16T15:34:35.952Z","version_downloads":27,"platform":"ruby","authors":"Jahfer Husain","info":"Ori is a library for Ruby that provides a robust set of primitives for building concurrent applications. The name comes from the Japanese word 折り \"ori\" meaning \"fold\", reflecting how concurrent operations interleave. Ori provides a set of primitives that allow you to build concurrent applications—that is, applications that interleave execution within a single thread—without blocking the entire Ruby interpreter for each task.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/jahfer/ori","changelog_uri":"https://github.com/jahfer/ori/releases","source_code_uri":"https://github.com/jahfer/ori"},"yanked":false,"sha":"bd1a08a290fe74e78e1045124170e811598f47f99f75e25fc5156cdb5939c12c","spec_sha":"1361f6b822b5795dbd1061565bb25f5c7a480e2a4d40952b153d4e29de5e7d9e","project_uri":"https://rubygems.org/gems/ori-rb","gem_uri":"https://rubygems.org/gems/ori-rb-0.4.4.gem","homepage_uri":"https://github.com/jahfer/ori","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/jahfer/ori","bug_tracker_uri":null,"changelog_uri":"https://github.com/jahfer/ori/releases","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"nio4r","requirements":"~> 2.7"},{"name":"zeitwerk","requirements":"~> 2.7.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/jahfer/ori"}