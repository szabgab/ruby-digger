{"gems":{"name":"ori-rb","downloads":801,"version":"0.4.5","version_created_at":"2026-03-18T12:15:40.917Z","version_downloads":0,"platform":"ruby","authors":"Jahfer Husain","info":"Ori is a library for Ruby that provides a robust set of primitives for building concurrent applications. The name comes from the Japanese word 折り \"ori\" meaning \"fold\", reflecting how concurrent operations interleave. Ori provides a set of primitives that allow you to build concurrent applications—that is, applications that interleave execution within a single thread—without blocking the entire Ruby interpreter for each task.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/jahfer/ori","changelog_uri":"https://github.com/jahfer/ori/releases","source_code_uri":"https://github.com/jahfer/ori"},"yanked":false,"sha":"5395b24971da3c91515a62f08a8b87ab2f24463529bc00acf10e5cfc7f74a4dd","spec_sha":"8922cd03e9d624e76f307364c665890a5d6f6183ae18c4362dd98d243659507c","project_uri":"https://rubygems.org/gems/ori-rb","gem_uri":"https://rubygems.org/gems/ori-rb-0.4.5.gem","homepage_uri":"https://github.com/jahfer/ori","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/jahfer/ori","bug_tracker_uri":null,"changelog_uri":"https://github.com/jahfer/ori/releases","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"nio4r","requirements":"~> 2.7"},{"name":"zeitwerk","requirements":"~> 2.7.1"}]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/jahfer/ori"}