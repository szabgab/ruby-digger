{"gems":{"name":"mathtype_to_mathml_plus","downloads":1092,"version":"0.0.15","version_created_at":"2026-03-02T04:37:12.162Z","version_downloads":35,"platform":"ruby","authors":"David Vu","info":"This gem can be used to convert MathType equations from a binary format (e.g. embedded in Word documents) to an open MathML representation. It achieves that in several stages, first using the \"mathtype\" gem to convert from a binary to an XML form of MTEF, and second, using XSLTs to convert XML to MathML.","licenses":["MIT"],"metadata":{},"yanked":false,"sha":"94ad772f2453a824000c666c99b3929cac128fe1b59d3b753052b97c780c771d","spec_sha":"1415b02828c2d6099918072330af2505765da4759536688975c021f18c8f1909","project_uri":"https://rubygems.org/gems/mathtype_to_mathml_plus","gem_uri":"https://rubygems.org/gems/mathtype_to_mathml_plus-0.0.15.gem","homepage_uri":"https://github.com/vuhonglinh","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/mathtype_to_mathml_plus/0.0.15","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"bundler","requirements":"~> 1.7"},{"name":"equivalent-xml","requirements":"~> 0.6"},{"name":"pry","requirements":"~> 0.10"},{"name":"rake","requirements":"~> 10.0"},{"name":"rspec","requirements":"~> 3.3"}],"runtime":[{"name":"mathtype","requirements":"~> 0.0.8"},{"name":"nokogiri","requirements":"~> 1.6"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/vuhonglinh"}