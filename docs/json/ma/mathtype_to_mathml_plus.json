{"gems":{"name":"mathtype_to_mathml_plus","downloads":1283,"version":"0.0.16","version_created_at":"2026-03-09T05:00:37.485Z","version_downloads":22,"platform":"ruby","authors":"David Vu","info":"This gem can be used to convert MathType equations from a binary format (e.g. embedded in Word documents) to an open MathML representation. It achieves that in several stages, first using the \"mathtype\" gem to convert from a binary to an XML form of MTEF, and second, using XSLTs to convert XML to MathML.","licenses":["MIT"],"metadata":{},"yanked":false,"sha":"d2d3b9d507b8bd19424f6a5dd1425aa0e27d27a55b695b127b18f01a463b0064","spec_sha":"0ea1f3430b632b93e4222ea851f38a8e49227e6d0aacfe400d8a5339d72956d3","project_uri":"https://rubygems.org/gems/mathtype_to_mathml_plus","gem_uri":"https://rubygems.org/gems/mathtype_to_mathml_plus-0.0.16.gem","homepage_uri":"https://github.com/vuhonglinh","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/mathtype_to_mathml_plus/0.0.16","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"bundler","requirements":"~> 1.7"},{"name":"equivalent-xml","requirements":"~> 0.6"},{"name":"pry","requirements":"~> 0.10"},{"name":"rake","requirements":"~> 10.0"},{"name":"rspec","requirements":"~> 3.3"}],"runtime":[{"name":"mathtype","requirements":"~> 0.0.8"},{"name":"nokogiri","requirements":"~> 1.6"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/vuhonglinh"}