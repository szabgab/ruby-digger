{"gems":{"name":"pipeloader","downloads":201,"version":"0.0.2","version_created_at":"2026-06-19T12:11:21.394Z","version_downloads":66,"platform":"ruby","authors":"Joshua Hull","info":"During GraphQL response building, Pipeloader routes ActiveRecord SELECTs through a libpq pipeline so a query tree resolves in roughly one round trip per level — with plain resolvers and plain models, no Futures, no dataloader.load, no resolver changes. Also ships Pipeloader::Batch: declarative batch-loaded associations and aggregates that eliminate N+1 in plain ActiveRecord traversal via AR's own Preloader.","licenses":["MIT"],"metadata":{},"yanked":false,"sha":"690995709941c109c2af6da6158c97690192f0580d9a0ba54f04cc65cdaa4708","spec_sha":"4f21e20ee1f474606553aaa164626edb394b854355174bbe9ff78b9b32831196","project_uri":"https://rubygems.org/gems/pipeloader","gem_uri":"https://rubygems.org/gems/pipeloader-0.0.2.gem","homepage_uri":"https://github.com/joshbuddy/pipeloader","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/pipeloader/0.0.2","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":">= 5"},{"name":"rake","requirements":">= 13"},{"name":"simplecov","requirements":"~> 0.22"}],"runtime":[{"name":"activerecord","requirements":">= 7.1"},{"name":"activesupport","requirements":">= 7.1"},{"name":"graphql","requirements":">= 2.0"},{"name":"pg","requirements":">= 1.3"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/joshbuddy/pipeloader"}