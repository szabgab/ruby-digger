{"gems":{"name":"pipeloader","downloads":255,"version":"0.0.3","version_created_at":"2026-06-19T14:36:37.589Z","version_downloads":33,"platform":"ruby","authors":"Joshua Hull","info":"During GraphQL response building, Pipeloader routes ActiveRecord SELECTs through a libpq pipeline so a query tree resolves in roughly one round trip per level — with plain resolvers and plain models, no Futures, no dataloader.load, no resolver changes. Also ships Pipeloader::Batch: declarative batch-loaded associations and aggregates that eliminate N+1 in plain ActiveRecord traversal via AR's own Preloader.","licenses":["MIT"],"metadata":{},"yanked":false,"sha":"2e76103f83ad3471ce82cbc6db3996e4e31d2441a6a76ded96688cd8eb2b8944","spec_sha":"4b0ab173768550b21043aa4794da0e106775ea87cf56f358fd4baee916f7deec","project_uri":"https://rubygems.org/gems/pipeloader","gem_uri":"https://rubygems.org/gems/pipeloader-0.0.3.gem","homepage_uri":"https://github.com/joshbuddy/pipeloader","wiki_uri":null,"documentation_uri":"https://www.rubydoc.info/gems/pipeloader/0.0.3","mailing_list_uri":null,"source_code_uri":null,"bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"minitest","requirements":">= 5"},{"name":"rake","requirements":">= 13"},{"name":"simplecov","requirements":"~> 0.22"}],"runtime":[{"name":"activerecord","requirements":">= 7.1"},{"name":"activesupport","requirements":">= 7.1"},{"name":"graphql","requirements":">= 2.0"},{"name":"pg","requirements":">= 1.3"}]}},"vcs_name":"GitHub","ci":null,"vcs_error":"ERROR","vcs_uri":"https://github.com/joshbuddy/pipeloader"}