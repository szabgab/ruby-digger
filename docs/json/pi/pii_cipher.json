{"gems":{"name":"pii_cipher","downloads":345,"version":"0.1.1","version_created_at":"2026-06-29T14:54:41.815Z","version_downloads":43,"platform":"ruby","authors":"Selva Chezhian","info":"PiiCipher lets you search encrypted PII columns in ActiveRecord without ever\nstoring or querying plaintext. It generates HMAC-SHA256 blind indexes alongside\nyour ciphertext — trigram arrays for partial (substring) searches and single\nhashes for exact-match lookups. The hash functions run in a native Rust\nextension for performance. Query interception is transparent: call `where`\nas normal and PiiCipher rewrites the query against the blind index automatically.\n","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/selvachezhian/pii_cipher","changelog_uri":"https://github.com/selvachezhian/pii_cipher/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/selvachezhian/pii_cipher","allowed_push_host":"https://rubygems.org"},"yanked":false,"sha":"c6b85a8ea0097d1c82e88fd42068a95526bf2cd5eb214eb6c9b7be380cbcbf5d","spec_sha":"c589802baa2e8c91864766352081aa8a439da1f85c9e9a12507d5e1a6d5c52a1","project_uri":"https://rubygems.org/gems/pii_cipher","gem_uri":"https://rubygems.org/gems/pii_cipher-0.1.1.gem","homepage_uri":"https://github.com/selvachezhian/pii_cipher","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/selvachezhian/pii_cipher","bug_tracker_uri":null,"changelog_uri":"https://github.com/selvachezhian/pii_cipher/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"activerecord","requirements":">= 7.1"},{"name":"railties","requirements":">= 7.1"},{"name":"rb_sys","requirements":"~> 0.9.128"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/selvachezhian/pii_cipher"}