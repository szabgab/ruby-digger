{"gems":{"name":"tans-parser","downloads":386,"version":"0.1.3","version_created_at":"2026-06-06T10:17:54.443Z","version_downloads":22,"platform":"ruby","authors":"Haluk Durmus","info":"tans-parser parses raw terminal output with ANSI escape sequences into a structured grid representation with per-cell attributes (char, fg, bg, bold, italic, underline, blink). Includes a query API (State) for text search, color inspection, and JSON output, plus heuristic UI element recognition (Selector) for buttons, checkboxes, dialogs, statusbars, and progress bars.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/vurte/tans-parser","source_code_uri":"https://github.com/vurte/tans-parser","rubygems_mfa_required":"true"},"yanked":false,"sha":"6ca65813f0d219067e1ea45b0c1d6a2d4562b632d9381ab17063b500f7b2a974","spec_sha":"8fe4a89077a89d825abb4e0b979039340922be613a227f89915cb7009912be72","project_uri":"https://rubygems.org/gems/tans-parser","gem_uri":"https://rubygems.org/gems/tans-parser-0.1.3.gem","homepage_uri":"https://github.com/vurte/tans-parser","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/vurte/tans-parser","bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"bundler-audit","requirements":"~> 0.9"},{"name":"pry","requirements":"~> 0.14"},{"name":"reek","requirements":"~> 6.3"},{"name":"rspec","requirements":"~> 3.12"},{"name":"rubocop","requirements":"~> 1.50"},{"name":"rubocop-rake","requirements":"~> 0.7"},{"name":"rubocop-rspec","requirements":"~> 3.6"},{"name":"simplecov","requirements":"~> 0.22"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/vurte/tans-parser"}