{"gems":{"name":"tans-parser","downloads":537,"version":"0.1.4","version_created_at":"2026-06-07T19:27:50.183Z","version_downloads":0,"platform":"ruby","authors":"Haluk Durmus","info":"tans-parser parses raw terminal output with ANSI escape sequences into a structured grid representation with per-cell attributes (char, fg, bg, bold, italic, underline, blink). Includes a query API (State) for text search, color inspection, and JSON output, plus heuristic UI element recognition (Selector) for buttons, checkboxes, dialogs, statusbars, and progress bars.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/vurte/tans-parser","source_code_uri":"https://github.com/vurte/tans-parser","rubygems_mfa_required":"true"},"yanked":false,"sha":"0fe0ab2a8c7dc102a53bbea640ff82cce0aa5a4abcafc7ae97c5b5848968ffae","spec_sha":"dc4009962a154eccc0cd185d036a620c3459c019a00bde6eb5f79b49e07b16d4","project_uri":"https://rubygems.org/gems/tans-parser","gem_uri":"https://rubygems.org/gems/tans-parser-0.1.4.gem","homepage_uri":"https://github.com/vurte/tans-parser","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/vurte/tans-parser","bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"bundler-audit","requirements":"~> 0.9"},{"name":"pry","requirements":"~> 0.14"},{"name":"reek","requirements":"~> 6.3"},{"name":"rspec","requirements":"~> 3.12"},{"name":"rubocop","requirements":"~> 1.50"},{"name":"rubocop-rake","requirements":"~> 0.7"},{"name":"rubocop-rspec","requirements":"~> 3.6"},{"name":"simplecov","requirements":"~> 0.22"}],"runtime":[{"name":"unicode-display_width","requirements":"~> 2.5"}]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/vurte/tans-parser"}