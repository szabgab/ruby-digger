{"gems":{"name":"tans-parser","downloads":270,"version":"0.1.1","version_created_at":"2026-06-03T19:59:29.983Z","version_downloads":56,"platform":"ruby","authors":"Haluk Durmus","info":"tans-parser parses raw terminal output with ANSI escape sequences into a structured grid representation with per-cell attributes (char, fg, bg, bold, italic, underline, blink). Includes a query API (State) for text search, color inspection, and JSON output, plus heuristic UI element recognition (Selector) for buttons, checkboxes, dialogs, statusbars, and progress bars.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/vurte/tans-parser","source_code_uri":"https://github.com/vurte/tans-parser","rubygems_mfa_required":"true"},"yanked":false,"sha":"240af666725bbc2622650d66f2df5fc362b7cb327dcff2ecba711946e3ab6a27","spec_sha":"2c93121f8e4012e618c873387179f7ddda172aa25271ad40e3450b6e614e0d2d","project_uri":"https://rubygems.org/gems/tans-parser","gem_uri":"https://rubygems.org/gems/tans-parser-0.1.1.gem","homepage_uri":"https://github.com/vurte/tans-parser","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/vurte/tans-parser","bug_tracker_uri":null,"changelog_uri":null,"funding_uri":null,"dependencies":{"development":[{"name":"bundler-audit","requirements":"~> 0.9"},{"name":"pry","requirements":"~> 0.14"},{"name":"reek","requirements":"~> 6.3"},{"name":"rspec","requirements":"~> 3.12"},{"name":"rubocop","requirements":"~> 1.50"},{"name":"rubocop-rake","requirements":"~> 0.7"},{"name":"rubocop-rspec","requirements":"~> 3.6"},{"name":"simplecov","requirements":"~> 0.22"}],"runtime":[]}},"vcs_name":"GitHub","ci":null,"vcs_uri":"https://github.com/vurte/tans-parser"}