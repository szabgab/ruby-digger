{"gems":{"name":"ucode","downloads":2084,"version":"0.3.1","version_created_at":"2026-07-03T09:27:34.970Z","version_downloads":184,"platform":"ruby","authors":"Ribose Inc.","info":"ucode turns the Unicode Character Database (UCD) text files and the official\nUnicode Code Charts into a structured, browsable dataset. For every assigned\ncodepoint it produces a JSON document with full UCD properties, the\nhuman-curated relationships from NamesList.txt, Unihan readings, and\nmachine-computed references; an SVG of the official glyph vector-extracted\nfrom the Code Charts; and a Vitepress site for browsing Plane, Block,\nand Character.\n","licenses":["BSD-2-Clause"],"metadata":{"homepage_uri":"https://github.com/fontist/ucode","changelog_uri":"https://github.com/fontist/ucode/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/fontist/ucode","rubygems_mfa_required":"true"},"yanked":false,"sha":"238f942ccda33bd63af9474001681bc09f7cca4920810727e2ffd219355c4f82","spec_sha":"718417af137120c5f2469d1488eb078b2c3f727389ac701e8e265880c6f0c9d7","project_uri":"https://rubygems.org/gems/ucode","gem_uri":"https://rubygems.org/gems/ucode-0.3.1.gem","homepage_uri":"https://github.com/fontist/ucode","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/fontist/ucode","bug_tracker_uri":null,"changelog_uri":"https://github.com/fontist/ucode/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[],"runtime":[{"name":"base64","requirements":">= 0"},{"name":"fontisan","requirements":"= 0.2.22"},{"name":"fontist","requirements":"~> 3.0"},{"name":"logger","requirements":">= 0"},{"name":"lutaml-model","requirements":"~> 0.8"},{"name":"nokogiri","requirements":"~> 1.16"},{"name":"rubyzip","requirements":"~> 2.3"},{"name":"sqlite3","requirements":"~> 2.0"},{"name":"thor","requirements":"~> 1.3"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/fontist/ucode"}