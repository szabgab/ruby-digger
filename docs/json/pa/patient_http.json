{"gems":{"name":"patient_http","downloads":3049,"version":"1.3.0","version_created_at":"2026-07-11T02:01:01.666Z","version_downloads":147,"platform":"ruby","authors":"Brian Durand","info":"This gem provides a dedicated async HTTP processor that uses Ruby's Fiber scheduler for non-blocking I/O. Application threads hand off HTTP requests to the processor and return immediately. The processor handles hundreds of concurrent HTTP connections using fibers, then notifies the application when responses arrive via a pluggable callback mechanism. This design keeps application threads free to do other work while HTTP requests are in flight.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/bdurand/patient_http","changelog_uri":"https://github.com/bdurand/patient_http/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/bdurand/patient_http"},"yanked":false,"sha":"b43f816f638e956ad610fe525bcc3b12bfeb6ce07c340da61ad5c6c057a349cf","spec_sha":"232abdf84f00d4e8ae79bdb880d99148876ee485a60946a95b6f974cff9ae2fd","project_uri":"https://rubygems.org/gems/patient_http","gem_uri":"https://rubygems.org/gems/patient_http-1.3.0.gem","homepage_uri":"https://github.com/bdurand/patient_http","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/bdurand/patient_http","bug_tracker_uri":null,"changelog_uri":"https://github.com/bdurand/patient_http/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"bundler","requirements":">= 0"}],"runtime":[{"name":"async","requirements":"~> 2.0"},{"name":"async-http","requirements":"~> 0.60"},{"name":"concurrent-ruby","requirements":"~> 1.2"},{"name":"logger","requirements":">= 0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/bdurand/patient_http"}