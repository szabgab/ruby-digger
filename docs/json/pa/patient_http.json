{"gems":{"name":"patient_http","downloads":293,"version":"1.1.0","version_created_at":"2026-06-08T05:10:44.616Z","version_downloads":23,"platform":"ruby","authors":"Brian Durand","info":"This gem provides a dedicated async HTTP processor that uses Ruby's Fiber scheduler for non-blocking I/O. Application threads hand off HTTP requests to the processor and return immediately. The processor handles hundreds of concurrent HTTP connections using fibers, then notifies the application when responses arrive via a pluggable callback mechanism. This design keeps application threads free to do other work while HTTP requests are in flight.","licenses":["MIT"],"metadata":{"homepage_uri":"https://github.com/bdurand/patient_http","changelog_uri":"https://github.com/bdurand/patient_http/blob/main/CHANGELOG.md","source_code_uri":"https://github.com/bdurand/patient_http"},"yanked":false,"sha":"8df9429ceb85cab37642b7ac11f6e02bd17ac119c14e13ed0d95ba11f1f6f820","spec_sha":"e1ce55b7b3a19d22eaca5f8a956cce0f48b21be5c7b303aa4e6a7ccd709b3539","project_uri":"https://rubygems.org/gems/patient_http","gem_uri":"https://rubygems.org/gems/patient_http-1.1.0.gem","homepage_uri":"https://github.com/bdurand/patient_http","wiki_uri":null,"documentation_uri":null,"mailing_list_uri":null,"source_code_uri":"https://github.com/bdurand/patient_http","bug_tracker_uri":null,"changelog_uri":"https://github.com/bdurand/patient_http/blob/main/CHANGELOG.md","funding_uri":null,"dependencies":{"development":[{"name":"bundler","requirements":">= 0"}],"runtime":[{"name":"async","requirements":"~> 2.0"},{"name":"async-http","requirements":"~> 0.60"},{"name":"concurrent-ruby","requirements":"~> 1.2"},{"name":"logger","requirements":">= 0"}]}},"vcs_name":"GitHub","ci":1,"github_actions":1,"vcs_uri":"https://github.com/bdurand/patient_http"}